    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002235">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002232"/>
        <obo:IAO_0000111>pT1 (lung)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is 3 cm or less in greatest dimension, surrounded by lung or visceral pleura without bronchoscopic evidence of invasion more proximal than the lobar bronchus (i.e., not in the main bronchus).</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>https://staging.seer.cancer.gov/tnm/input/1.0/lung/path_t/</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>pT1 (lung)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002236 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0002236">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/OBI_0002232"/>
        <obo:IAO_0000111>pT1a (lung)</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A pathologic primary tumor stage for lung according to AJCC 7th edition indicating that the tumor is 2 cm or less in greatest dimension.</obo:IAO_0000115>
        <obo:IAO_0000117>Chris Stoeckert, Helena Ellis</obo:IAO_0000117>
        <obo:IAO_0000119>https://staging.seer.cancer.gov/tnm/input/1.0/lung/path_t/</obo:IAO_0000119>
        <obo:IAO_0000234>NCI BBRB</obo:IAO_0000234>
        <rdfs:label>pT1a (lung)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0002237 -->

