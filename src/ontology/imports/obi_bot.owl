                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111 xml:lang="en">material component separation</obo:IAO_0000111>
        <obo:IAO_0000112 xml:lang="en">Using a cell sorter to separate a mixture of T cells into two fractions; one with surface receptor CD8 and the other lacking the receptor, or purification</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">a material processing in which components of an input material become segregated in space</obo:IAO_0000115>
        <obo:IAO_0000117 xml:lang="en">Bjoern Peters</obo:IAO_0000117>
        <obo:IAO_0000119 xml:lang="en">IEDB</obo:IAO_0000119>
        <rdfs:label xml:lang="en">material component separation</rdfs:label>
    </owl:Class>
    


