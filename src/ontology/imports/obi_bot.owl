            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111>infection process</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">the detrimental process in which an infectious agent colonizes or replicates in a host environment</obo:IAO_0000115>
        <obo:IAO_0000117 xml:lang="en">IEDB</obo:IAO_0000117>
        <obo:IAO_0000119 xml:lang="en">IEDB</obo:IAO_0000119>
