        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000120"/>
        <obo:IAO_0000115 xml:lang="en">A planned process with the objective to preserve and protect material entities by placing them in an identified location which may have a controlled environment.</obo:IAO_0000115>
        <obo:IAO_0000117>Philippe Rocca-Serra</obo:IAO_0000117>
        <obo:IAO_0000119>OBI-Branch</obo:IAO_0000119>
