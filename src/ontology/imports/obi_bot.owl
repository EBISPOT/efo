            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111 xml:lang="en">group assignment</obo:IAO_0000111>
        <obo:IAO_0000112 xml:lang="en">Assigning&apos; to be treated with active ingredient role&apos; to an organism during group assignment. The group is those organisms that have the same role in the context of an investigation</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">group assignment is a process which has an organism as specified input and during which a role is assigned</obo:IAO_0000115>
        <obo:IAO_0000117 xml:lang="en">Philippe Rocca-Serra</obo:IAO_0000117>
        <obo:IAO_0000118>cohort assignment</obo:IAO_0000118>
        <obo:IAO_0000118>study assignment</obo:IAO_0000118>
        <obo:IAO_0000119 xml:lang="en">OBI Plan</obo:IAO_0000119>
        <rdfs:label xml:lang="en">group assignment</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_0600024 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0600024">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000838"/>
