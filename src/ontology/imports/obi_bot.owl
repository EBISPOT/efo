        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000123"/>
        <obo:IAO_0000115 xml:lang="en">An organization that supplies life science tools for translational research and molecular diagnostics based on a novel digital molecular barcoding technology. The NanoString platform can provide simple, multiplexed digital profiling of single molecules.</obo:IAO_0000115>
        <rdfs:label>NanoString Technologies</rdfs:label>
    </owl:NamedIndividual>
    


