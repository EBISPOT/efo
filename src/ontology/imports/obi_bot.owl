    <!-- http://purl.obolibrary.org/obo/OBI_0000977 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000977">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0302893"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                <owl:someValuesFrom>
