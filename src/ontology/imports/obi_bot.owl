    <!-- http://purl.obolibrary.org/obo/OBI_0000915 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000915">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0302893"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom>
