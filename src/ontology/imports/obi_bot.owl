            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111 xml:lang="en">adding substance to cell culture</obo:IAO_0000111>
        <obo:IAO_0000112 xml:lang="en">adding fetal calf serum to a 96 well plate containing a cell culture derived from a blood sample of a patient</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000125"/>
        <obo:IAO_0000115 xml:lang="en">is process in which a material substance is added to a cell culture</obo:IAO_0000115>
        <obo:IAO_0000116>renamed from &apos;administering substance to cell culture&apos;, to reflect that administration is commonly used only for organisms</obo:IAO_0000116>
        <obo:IAO_0000117 xml:lang="en">Bjoern Peters</obo:IAO_0000117>
        <obo:IAO_0000119 xml:lang="en">IEDB</obo:IAO_0000119>
        <rdfs:label xml:lang="en">adding substance to cell culture</rdfs:label>
    </owl:Class>
    


