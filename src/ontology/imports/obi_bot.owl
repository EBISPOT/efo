    <!-- http://purl.obolibrary.org/obo/OBI_0002743 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0002743">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000086"/>
