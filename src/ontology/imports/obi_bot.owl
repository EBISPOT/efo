    <!-- http://purl.obolibrary.org/obo/OBI_0400106 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0400106">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000832"/>
