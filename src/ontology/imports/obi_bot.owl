    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_1110022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_1110022">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0019815"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0042101"/>
