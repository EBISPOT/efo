    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0600036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000110"/>
        <rdfs:subClassOf>
            <owl:Restriction>
