                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000164"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000722"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_0000736"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBI_1000029"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
