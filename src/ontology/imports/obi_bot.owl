        <obo:IAO_0000111 xml:lang="en">regulatory agency</obo:IAO_0000111>
        <obo:IAO_0000112>The US Environmental Protection Agency</obo:IAO_0000112>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A regulatory agency is a organization that has responsibility over or for  the legislation (acts and regulations) for a given sector of the government.</obo:IAO_0000115>
        <obo:IAO_0000117>GROUP: OBI Biomaterial Branch</obo:IAO_0000117>
        <obo:IAO_0000119>WEB: en.wikipedia.org/wiki/Regulator</obo:IAO_0000119>
        <rdfs:label xml:lang="en">regulatory agency</rdfs:label>
