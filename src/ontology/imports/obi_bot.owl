    <!-- http://purl.obolibrary.org/obo/OBI_0000327 -->

    <owl:NamedIndividual rdf:about="http://purl.obolibrary.org/obo/OBI_0000327">
        <rdf:type rdf:resource="http://purl.obolibrary.org/obo/IAO_0000098"/>
        <obo:IAO_0000111 xml:lang="en">FCS</obo:IAO_0000111>
        <obo:IAO_0000112 xml:lang="en">d01.fcs, FCS3 data file of well D06 of plate 2 of part 1 of a GvHD experiment.</obo:IAO_0000112>
