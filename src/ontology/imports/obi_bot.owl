    <!-- http://purl.obolibrary.org/obo/OBI_0000453 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0000453">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000034"/>
        <rdfs:subClassOf>
            <owl:Restriction>
