modification of definition and replacement of biomaterials in previous definition with &apos;material&apos;
addition of has_role restriction</obo:IAO_0000232>
        <rdfs:label xml:lang="en">phage display library</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBI_1110021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_1110021">
