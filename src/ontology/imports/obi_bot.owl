                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBI_0000648"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111>clustered data visualization</obo:IAO_0000111>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000123"/>
        <obo:IAO_0000115 xml:lang="en">A data visualization which has input of a clustered data set and produces an output of a report graph which is capable of rendering data of this type.</obo:IAO_0000115>
        <obo:IAO_0000117>James Malone</obo:IAO_0000117>
        <rdfs:label>clustered data visualization</rdfs:label>
    </owl:Class>
    


