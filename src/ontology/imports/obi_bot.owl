        <obo:IAO_0000115 xml:lang="en">a process in which a population of cells with certain characteristics is isolated from a larger population</obo:IAO_0000115>
        <obo:IAO_0000117>Person: Bjoern Peters</obo:IAO_0000117>
        <rdfs:label>isolation of cell population</rdfs:label>
    </owl:Class>
    


