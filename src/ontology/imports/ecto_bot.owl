        <obo:IAO_0000115>Hydrological precipitation is a process during which any product of the condensation of atmospheric water vapour is pulled to the planetary surface by gravity.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>precipitation</oboInOwl:hasBroadSynonym>
        <rdfs:comment>&quot;process&quot; is included in the label to make it clear that we are not referring to the precipitated material (e.g. snow, rain, sleet)</rdfs:comment>
        <rdfs:label xml:lang="en">hydrological precipitation process</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000703"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Hydrological precipitation is a process during which any product of the condensation of atmospheric water vapour is pulled to the planetary surface by gravity.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Precipitation</oboInOwl:hasDbXref>
    </owl:Axiom>
    


