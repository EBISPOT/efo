        <obo:IAO_0000115>A mass of snow.</obo:IAO_0000115>
        <obo:IAO_0000117 rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <obo:IAO_0000117>http://orcid.org/0000-0002-3410-4655</obo:IAO_0000117>
        <oboInOwl:hasBroadSynonym>accumulation of snow</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>snow accumulation</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>http://sweetontology.net/phenCryo/Accumulation</oboInOwl:hasDbXref>
