        <obo:IAO_0000115>A portion of contaminated soil is a portion of soil with elevated levels of some contaminant.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>ENVO</oboInOwl:hasOBONamespace>
        <oboInOwl:id>ENVO:00002116</oboInOwl:id>
