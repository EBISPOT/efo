        <obo:IAO_0000115>A lentic water body is a water body in which the accumulated water, in its totality, has very little to no directed flow.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">lentic water body</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01000624 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01000624">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000724"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_02500031"/>
