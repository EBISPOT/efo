        <oboInOwl:hasDbXref rdf:resource="https://en.wikipedia.org/wiki/Weather_front"/>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001681"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget>This class refers to Earth&apos;s weather fronts. Other forms, not composed of air, are present on other planets and can be created on request. Note: &quot;Since the temperature distribution is the most important regulator of atmospheric density, a front almost invariably separates air masses of different temperature. Along with the basic density criterion and the common temperature criterion, many other features may distinguish a front, such as a pressure trough, a change in wind direction, a moisture discontinuity, and certain characteristic cloud and precipitation forms.&quot;</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:resource="http://glossary.ametsoc.org/wiki/Front"/>
    </owl:Axiom>
    


