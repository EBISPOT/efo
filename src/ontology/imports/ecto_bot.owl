        <obo:IAO_0000115 xml:lang="en">A surface layer which is part of an ocean or sea.</obo:IAO_0000115>
        <dc:contributor rdf:resource="https://orcid.org/0000-0002-2996-719X"/>
        <dc:contributor rdf:resource="https://orcid.org/0000-0002-8166-0486"/>
        <dc:contributor rdf:resource="https://orcid.org/0000-0003-1072-8081"/>
