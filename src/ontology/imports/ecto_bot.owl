            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A type of land degradation in which terrestrial ecosystem becomes increasingly dry, typically losing its bodies of water as well as vegetation and wildlife.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">desertification</rdfs:label>
    </owl:Class>
