                        <swrl:argument1 rdf:resource="urn:swrl:var#x"/>
                        <swrl:argument2 rdf:resource="urn:swrl:var#z"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
