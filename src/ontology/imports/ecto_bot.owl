                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/COB_0000801"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</owl:hasValue>
            </owl:Restriction>
        </owl:equivalentClass>
