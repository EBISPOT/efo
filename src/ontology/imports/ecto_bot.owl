                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000543"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001275"/>
