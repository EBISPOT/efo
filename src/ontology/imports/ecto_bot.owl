        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000123"/>
        <obo:IAO_0000117>Damion Dooley</obo:IAO_0000117>
        <rdfs:comment xml:lang="en">Damion Dooley&apos;s note: This category was created to organize SIREN inspired food products.  It will probably get merged with the upper level &apos;dietary supplement&apos; food product type items.</rdfs:comment>
        <rdfs:label xml:lang="en">dietary or therapeutic formulation food product</rdfs:label>
    </owl:Class>
    


