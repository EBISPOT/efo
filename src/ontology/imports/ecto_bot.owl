            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Environmental material derived from living organisms and composed primarily of one or more biomacromolecules.</obo:IAO_0000115>
        <obo:IAO_0000412 rdf:resource="http://purl.obolibrary.org/obo/envo.owl"/>
        <oboInOwl:created_by>ORCID:0000-0002-4366-3088</oboInOwl:created_by>
        <oboInOwl:creation_date>2010-03-20T08:40:04Z</oboInOwl:creation_date>
        <oboInOwl:hasDbXref>EcoLexicon:organic_material</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>biomass</oboInOwl:hasExactSynonym>
        <rdfs:label>organic material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000155"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
