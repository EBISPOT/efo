    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01003001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000016"/>
        <rdfs:subClassOf>
            <owl:Restriction>
