        <oboInOwl:hasRelatedSynonym>organelle organization and biogenesis</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>single-organism organelle organization</oboInOwl:hasRelatedSynonym>
