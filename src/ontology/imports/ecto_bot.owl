        <oboInOwl:hasRelatedSynonym>minerals</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>mineraux</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>CHEBI:46662</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/chebi#3_STAR"/>
        <rdfs:label>mineral</rdfs:label>
