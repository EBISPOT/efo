        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Planet</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01001125 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01001125">
