    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001714 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001714">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FOODON_00001002"/>
        <obo:IAO_0000115 xml:lang="en">A food product which normally exists as an ingredient to another food product, rather than eaten on its own, and is more complex than a chemical food component.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">food product component</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/FOODON_00001809 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FOODON_00001809">
