                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01000406"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_00000191"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002473"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_00000134"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01000277"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01000406"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A solid astronomical body part which is primarily composed of a continuous mass of snow and/or ice.</obo:IAO_0000115>
        <obo:IAO_0000116>Place holder class. Also the axiom should be changed to something along the lines of &apos;primairly composed of’ some ‘environmental material’ and ‘has quality’ frozen once PATO:frozen is imported.</obo:IAO_0000116>
        <obo:IAO_0000117 rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <obo:IAO_0000117>http://orcid.org/0000-0002-3410-4655</obo:IAO_0000117>
        <oboInOwl:inSubset>envoPolar</oboInOwl:inSubset>
        <rdfs:label xml:lang="en">cryoform</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_03000111 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_03000111">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01001691"/>
