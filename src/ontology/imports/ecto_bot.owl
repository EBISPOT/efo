        <oboInOwl:hasDbXref>MA:ma</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Ocean</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_00001995 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_00001995">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000814"/>
        <rdfs:subClassOf>
