                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A planet which has a surface layer that nearly completely or completely covered by water, and which has a substantial portion of its mass composed of water.</obo:IAO_0000115>
        <obo:IAO_0000116>An axiom to express that the planet has a &apos;substantial&apos; proportion of its mass in the form of water wound enhance this class.</obo:IAO_0000116>
        <oboInOwl:hasExactSynonym>aquaplanet</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>panthalassic planet</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>water world</oboInOwl:hasExactSynonym>
        <oboInOwl:inSubset>envoAstro</oboInOwl:inSubset>
        <rdfs:comment>While this planetary form is still mostly theoretical, strong candidates exist such as the extrasolar planet GJ 1214 b and ocean planet candidate Kepler-22b.</rdfs:comment>
        <rdfs:label xml:lang="en">ocean planet</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001136"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A planet which has a surface layer that nearly completely or completely covered by water, and which has a substantial portion of its mass composed of water.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://en.wikipedia.org/wiki/Ocean_planet</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01001137 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01001137">
        <owl:equivalentClass>
