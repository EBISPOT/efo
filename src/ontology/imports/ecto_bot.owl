        <obo:IAO_0000115>A planet which is primarily composed of hydrogen and helium.</obo:IAO_0000115>
        <oboInOwl:inSubset>envoAstro</oboInOwl:inSubset>
        <rdfs:comment>Gas giants are composed of about 90% hydrogen and helium. Jupiter and Saturn are examples of gas giants.</rdfs:comment>
        <rdfs:label xml:lang="en">gas planet</rdfs:label>
    </owl:Class>
