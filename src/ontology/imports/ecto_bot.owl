        <obo:IAO_0000115>A terrestrial planet which has a surface dominated by hot deserts.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>dry planet</oboInOwl:hasExactSynonym>
        <oboInOwl:inSubset>envoAstro</oboInOwl:inSubset>
        <rdfs:comment>This class of planet is still mostly theoretical.</rdfs:comment>
        <rdfs:label xml:lang="en">desert planet</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/ENVO_01001136 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/ENVO_01001136">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/ENVO_01000800"/>
                    <owl:Restriction>
