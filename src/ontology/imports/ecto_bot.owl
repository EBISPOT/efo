        <obo:IAO_0000115>The concentration of carbon dioxide when measured in air that is part of an atmosphere.</obo:IAO_0000115>
        <dc:creator rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <dc:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-05-19T22:51:38Z</dc:date>
        <oboInOwl:inSubset>envoAtmo</oboInOwl:inSubset>
        <oboInOwl:inSubset>envoNceas</oboInOwl:inSubset>
