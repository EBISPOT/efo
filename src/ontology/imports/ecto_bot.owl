        <obo:IAO_0000115>Land which is below the freezing point of water.</obo:IAO_0000115>
        <oboInOwl:created_by rdf:resource="https://orcid.org/0000-0002-4366-3088"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-01-14T21:18:19Z</oboInOwl:creation_date>
        <oboInOwl:hasDbXref>http://sweetontology.net/realmCryo/FrozenGround</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>frozen ground</oboInOwl:hasExactSynonym>
        <rdfs:comment>Perennially and seasonally frozen ground can vary from being partially to extensively frozen depending on the extent of the phase change. It may be described as hard frozen ground, plastic frozen ground, or dry frozen ground, depending on the pore ice and unfrozen water contents and its compressibility under load.</rdfs:comment>
        <rdfs:label xml:lang="en">frozen land</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001524"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Land which is below the freezing point of water.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0003-4808-4736</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001524"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
        <owl:annotatedTarget>Perennially and seasonally frozen ground can vary from being partially to extensively frozen depending on the extent of the phase change. It may be described as hard frozen ground, plastic frozen ground, or dry frozen ground, depending on the pore ice and unfrozen water contents and its compressibility under load.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0003-4808-4736</oboInOwl:hasDbXref>
    </owl:Axiom>
    


