        <obo:IAO_0000115>A biome which is determined by a water body and which has ecological climax communities adapted to life in or on water.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>LTER:41</oboInOwl:hasDbXref>
        <rdfs:label>aquatic biome</rdfs:label>
    </owl:Class>
    


