        </rdfs:subClassOf>
        <obo:IAO_0000114 rdf:resource="http://purl.obolibrary.org/obo/IAO_0000122"/>
        <obo:IAO_0000115 xml:lang="en">A food product which is derived from or produced by an animal that has a vertibrae.</obo:IAO_0000115>
        <obo:IAO_0000117>Damion Dooley</obo:IAO_0000117>
        <rdfs:label xml:lang="en">vertebrate animal food product</rdfs:label>
    </owl:Class>
    


