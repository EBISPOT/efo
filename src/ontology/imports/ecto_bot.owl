                                <swrl:propertyPredicate rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                                <swrl:argument1 rdf:resource="urn:swrl:var#x"/>
                                <swrl:argument2 rdf:resource="urn:swrl:var#y"/>
                            </rdf:Description>
