        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/ENVO_01001681"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A gaseous front which separates two masses of air with different densities and is a principal cause of meteorological phenomena.</owl:annotatedTarget>
