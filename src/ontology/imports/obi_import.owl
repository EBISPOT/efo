AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/OBI_0000124> "OBI")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBI_0000124> "is_supported_by_data")
