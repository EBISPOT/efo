AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBI_0000662> "error corrected data set"@en)
EquivalentClasses(<http://purl.obolibrary.org/obo/OBI_0000662> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/OBI_0000312> <http://purl.obolibrary.org/obo/OBI_0000668>))
