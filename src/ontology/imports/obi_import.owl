AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/OBI_0000416> "cloning insert role"@en)
SubClassOf(<http://purl.obolibrary.org/obo/OBI_0000416> <http://purl.obolibrary.org/obo/BFO_0000023>)

