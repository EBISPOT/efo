# Class: <http://purl.obolibrary.org/obo/CL_4047101> (liver-resident natural killer cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:26330348") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:26639736") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:27798170") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31114585") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32351704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34230995") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35865550") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4047101> "A natural killer cell resident to the liver, located in the hepatic sinusoids. In humans this cell type is distinguished from circulating natural killer cells by CD49a or CD69 gene expression. Liver-resident natural killer cells have also been shown to express CCR5, EOMES, KLRB1, GZMK, and CXCR6 in humans.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4047101> <https://orcid.org/0009-0005-7919-4905>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4047101> "https://orcid.org/0000-0001-8134-3037")
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4047101> "2024-07-29T13:43:11Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31114585") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "he-NK")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "doi:10.3389/fimmu.2019.00946") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "hepatic NK")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "doi:10.3389/fimmu.2019.00946") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "hepatic natural killer cells")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:33828559") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "intrahepatic NK")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:26639736") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "liver NK cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:26330348") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "liver resident natural killer cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "liver-specific natural killer cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35726345") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4047101> "lr-NK")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34230995") rdfs:comment <http://purl.obolibrary.org/obo/CL_4047101> "Liver-resident natural killer cells play a crucial role in modulating the immune response during inflammation by balancing cytotoxic activity and cytokine production, thereby contributing to the maintenance of liver homeostasis and protection against excessive tissue damage.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4047101> "liver-resident natural killer cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4047101> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0000623> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0001025> <http://purl.obolibrary.org/obo/UBERON_0001281>)))
