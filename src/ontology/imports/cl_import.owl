AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000853> "sustentaculocyte of olfactory epithelium")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000853> "olfactory epithelial supporting cell")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#prefLabel> <http://purl.obolibrary.org/obo/CL_0000853> "olfactory epithelial supporting cell")
