# Class: <http://purl.obolibrary.org/obo/CL_4030034> (respiratory tract multiciliated cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18757316") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:21364219") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34044844") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:37834236") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4030034> "A multiciliated epithelial cell located in the respiratory tract epithelium, characterized by a columnar shape and motile cilia on its apical surface. This cell develops through a highly orchestrated process, transitioning from a basal progenitor via an intermediate deuterosomal cell stage that generates centrioles essential for ciliogenesis.")
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4030034> "2023-01-25T11:06:01Z"^^xsd:dateTime)
