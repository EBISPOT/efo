SubClassOf(<http://purl.obolibrary.org/obo/CL_4052035> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0009970>))

# Class: <http://purl.obolibrary.org/obo/CL_4052036> (tuft cell of nasal cavity)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30379593") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38306414") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052036> "A tuft cell that is part of the nasal cavity epithelium, located in both the respiratory and olfactory epithelia of the nose. This cell plays key roles in chemosensation, lipid mediator production, immune responses, and epithelial homeostasis.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052036> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052036> "2025-01-21T09:04:03Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34692913") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4052036> "nasal brush cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38306414") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4052036> "nasal tuft cell")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052036> "tuft cell of nasal cavity")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052036> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0005384>)))
