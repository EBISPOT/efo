# Class: <http://purl.obolibrary.org/obo/CL_3000001> (Hofbauer cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:CellBLAST") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30429548") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30498493") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34745147") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35438172") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_3000001> "A tissue-resident macrophage that is part of the placenta. A Hofbauer cell expresses high levels of growth factors and metalloproteinases that support vasculogenesis, angiogenesis, branching morphogenesis and tissue remodeling. A Hofbauer cell has a fetal origin, is found in the villous stroma, chorion, and amnion, and is present throughout pregnancy.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_3000001> <http://www.wikidata.org/entity/Q97529981>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_3000001> <https://orcid.org/0000-0001-6677-8489>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <http://purl.obolibrary.org/obo/CL_3000001> "2019-02-18T19:41:20Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:39007150") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_3000001> "fetal Hofbauer cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:39007150") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/OMO_0003000>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_3000001> "HBC")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/CL_3000001> "CL:3000001")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_3000001> <http://purl.obolibrary.org/obo/cl#cellxgene_subset>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_3000001> <http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas>)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30498493") rdfs:comment <http://purl.obolibrary.org/obo/CL_3000001> "Hofbauer cells are a heterogenic group of macrophages that resemble M2-like cells. Initially described in chorionic villi in humans, a Hofbauer cell is now often used to describe any fetal-derived placental macrophage that resides within the placental villous core, amnion, and chorion laeve.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_3000001> "Hofbauer cell")
SubClassOf(<http://purl.obolibrary.org/obo/CL_3000001> <http://purl.obolibrary.org/obo/CL_4033087>)

# Class: <http://purl.obolibrary.org/obo/CL_3000004> (peripheral sensory neuron)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:CellBLAST") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30096314") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31554486") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35858549") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Sensory_neuron") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://www.britannica.com/science/sensory-neuron") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://www.ncbi.nlm.nih.gov/books/NBK539846/") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_3000004> "A neuron type that is located in a peripheral nervous system and it transmits sensory information from the peripheral (PNS) to the central nervous system (CNS). A sensory neuron converts physical (light, sound, touch) or chemical (such as taste and smell) stimuli into an electrical signal through a process known as sensory transduction. The function of a sensory neuron is to carry informations from the external environment and internal body conditions to the central nervous system for further processing.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_3000004> <http://www.wikidata.org/entity/Q97529981>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <http://purl.obolibrary.org/obo/CL_3000004> "2019-02-25T19:34:33Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/CL_3000004> "CL:3000004")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Sensory_neuron") rdfs:comment <http://purl.obolibrary.org/obo/CL_3000004> "Typically, a sensory neuron has a pseudounipolar morphology.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_3000004> "peripheral sensory neuron")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_3000004> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_2000032> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0050906>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_3000004> <http://purl.obolibrary.org/obo/CL_0000101>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_3000004> <http://purl.obolibrary.org/obo/CL_2000032>)

