# Class: <http://purl.obolibrary.org/obo/CL_0000560> (band form neutrophil)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0721601464") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:10618520") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:12560239") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:15514007") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.cap.org") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000560> "A late neutrophilic metamyelocyte in which the nucleus is indented to more than half the distance to the farthest nuclear margin but in no area being condensed to a single filament. The nucleus is in the form of a curved or coiled band, not having acquired the typical multilobar shape of the mature neutrophil. These cells are fMLP receptor-positive, CD11b-positive, CD35-negative, and CD49d-negative.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000560> "band")
