# Class: <http://purl.obolibrary.org/obo/CL_4033083> (squamous granulosa cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:28892263") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4033083> "A granulosa cell that has a squamous morphology and form a single layer around the oocyte in primordial follicles. This cell develops directly into a cuboidal granulosa cell during the primordial-to-primary follicle transition.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4033083> <https://orcid.org/0000-0001-6677-8489>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4033083> "2024-09-24T13:13:24Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:22402964") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4033083> "flattened granulosa cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:33914868") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_4033083> "pre-granulosa cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:33914868") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/OMO_0003000>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_4033083> "squamous GC")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://orcid.org/0000-0001-6677-8489") rdfs:comment <http://purl.obolibrary.org/obo/CL_4033083> "Often in literature squamous granulosa cell and pre-granulosa cell are used as synonyms. However, this term only makes reference to the quiescent granulosa cells that surround the primordial ovarian follicle, while a pre-granulosa cell proliferates to form the primordial follicle (and thus cells become the squamous granulosa cells).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4033083> "squamous granulosa cell")
SubClassOf(<http://purl.obolibrary.org/obo/CL_4033083> <http://purl.obolibrary.org/obo/CL_0000501>)
