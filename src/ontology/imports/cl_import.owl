SubClassOf(<http://purl.obolibrary.org/obo/CL_0000453> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/CL_0000763>))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000453> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0002828>))

