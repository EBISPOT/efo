# Class: <http://purl.obolibrary.org/obo/CL_4052017> (choroid plexus capillary endothelial cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18480313") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32375819") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://www.ncbi.nlm.nih.gov/books/NBK27998/") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052017> "A capillary endothelial cell that is part of the choroid plexus, characterized by its fenestrated nature with 60 to 80 nm fenestrations and lack of tight junctions. This fenestrated structure allows for the rapid delivery of water and other components, aiding in the production of cerebrospinal fluid (CSF).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052017> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052017> "2024-10-01T11:38:22Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052017> "choroid plexus capillary endothelial cell")
