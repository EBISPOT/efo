# Class: <http://purl.obolibrary.org/obo/CL_0002378> (immature Vgamma2-positive fetal thymocyte)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.immgen.org") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0002378> "A double negative thymocyte that has a T cell receptor consisting of a gamma chain containing a Vgamma2 segment, and a delta chain. This cell type is CD4-negative, CD8-negative and CD24-positive and is found in the fetal thymus.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_0002378> <https://orcid.org/0000-0003-1980-3228>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#creation_date> <http://purl.obolibrary.org/obo/CL_0002378> "2010-10-07T02:21:07Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0002378> "fetal Vgamma2+ thymocyte")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0002378> "NOTE: currently variable immune gene segments are not represented in the OBO Foundry. Cross-product definitions were not made as a result. Also, there are three different nomenclatures for the variable gamma segments.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0002378> "immature Vgamma2-positive fetal thymocyte")
