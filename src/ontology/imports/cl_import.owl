AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000058> "chondroblast")
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#prefLabel> <http://purl.obolibrary.org/obo/CL_0000058> "chondroblast")
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000058> <http://purl.obolibrary.org/obo/CL_0002320>)
