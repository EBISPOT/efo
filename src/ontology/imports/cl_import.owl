# Class: <http://purl.obolibrary.org/obo/CL_0002526> (CD14-positive dermal dendritic cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:19236899") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20309010") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0002526> "A dermal dendritic cell that is CD1a-negative and CD14-positive.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0002526> "CD14+ dermal DC")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0002526> "They are also CD11c-positive, CD40-positive, CD85j-positive (ILT-2), CD163-positive, CD205-positive (DEC205), CD207-negative (langerin), CD209-positive (DC-SIGN), CD274-positive (PD-L1), CD324-negative (E-cadherin), Factor XIIIa-positive, LOX-I-positive, CLEC6-positive, Dectin-1-positive, and DCIR-positive. Upon stimulation, these cells are capable of producing IL1-beta, IL6, IL8, IL10, IL12p40, IL19, IL20, IL24, TGF-beta, TNF-alpha, GM-CSF, and MCP1. They reside in the dermis.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0002526> "CD14-positive dermal dendritic cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_0002526> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0001006> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/CL_4030046> <http://purl.obolibrary.org/obo/PR_000002025>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002104> <http://purl.obolibrary.org/obo/PR_000001889>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0045191>)))
