AnnotationAssertion(Annotation(rdfs:label "respiratory tract multiciliated cell on CELLxGENE CellGuide") rdfs:seeAlso <http://purl.obolibrary.org/obo/CL_4030034> "https://cellxgene.cziscience.com/cellguide/CL_4030034")
