# Class: <http://purl.obolibrary.org/obo/CL_0000165> (neuroendocrine cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "MESH:D055099") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000165> "A neuron that is capable of some hormone secretion in response to neuronal signals.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000165> "BTO:0002691")
