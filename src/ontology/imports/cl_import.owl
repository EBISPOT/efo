# Class: <http://purl.obolibrary.org/obo/CL_0020063> (tuft cell of parotid gland)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:23209333") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35993302") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38098741") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38358561") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0020063> "A tuft cell that is part of the epithelium of the parotid gland, localized to the striated ducts and never observed in acini. This cell is characterized by expression of POU2F3 and is expected to possess chemosensory function consistent with tuft cells in other tissues. Immunohistochemical analysis of normal human parotid gland tissue detected POU2F3-positive cells as a very rare population within the ductal compartment, positioned on the luminal side (Hoki et al., 2024).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_0020063> <https://orcid.org/0000-0002-5507-2103>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_0020063> "2026-03-24T10:46:30Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:3284416") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38358561") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0020063> "parotid gland tuft cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18062147") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:23209333") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_0020063> "brush cell of parotid gland")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0020063> "tuft cell of parotid gland")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_0020063> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0001831>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0020063> <http://purl.obolibrary.org/obo/CL_0002204>)
