# Class: <http://purl.obolibrary.org/obo/CL_0000484> (connective tissue type mast cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:19923473") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:9354811") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000484> "Mast cell subtype whose granules contain both the serine proteases tryptase and chymase. These cells are primarily found in connective tissue, such as the peritoneal cavity, skin, and intestinal submucosa. Their development is T-cell independent.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000484> "MC(TC)")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000484> "MCTC")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000484> "TC mast cells")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000484> <http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000484> "They are CD88-positive. The cytoplasmic granules contain high levels of histamine and heparin (mouse) or major neutral proteases, tryptase, chymase, carboxypeptidase A, and cathepsin G (humans). Reportedly, they cannot produce leukotrienes (LTC4) and IL-4. They are reportedly very heterogeneous depending upon location and can convert to the MC(T) phenotype.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000484> "connective tissue type mast cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_0000484> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0000097> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0002384>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000484> <http://purl.obolibrary.org/obo/CL_0000097>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000484> <http://purl.obolibrary.org/obo/CL_0002320>)

# Class: <http://purl.obolibrary.org/obo/CL_0000485> (mucosal type mast cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:19923473") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:9354811") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000485> "Mast cell subtype that contains only the serine protease trypase in its granules. These cells are primarily found in mucosal tissue, such as intestinal mucosa and alveoli. They depend upon T-cells for development of phenotype.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000485> "MC(T)")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000485> "MCT")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000485> "T mast cells")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000485> <http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000485> "They are CD88-negative. The cytoplasmic granules contain low levels of histamine and high levels of chondroitin sulfate (mouse) or major neutral proteases and tryptase (humans). Additionally, they can produce leukotrienes (LTC4), IL-5, IL-6, and low levels of IL-4. They are reportedly very heterogeneous depending upon location and can convert to the MC(T) phenotype.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000485> "mucosal type mast cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_0000485> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0000097> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0001961>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0002540>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000485> <http://purl.obolibrary.org/obo/CL_0000097>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000485> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0001961>))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000485> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0002540>))

# Class: <http://purl.obolibrary.org/obo/CL_0000492> (CD4-positive helper T cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:pam") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GO_REF:0000031") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0781735149") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "MESH:D006377") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000492> "A CD4-positive, alpha-beta T cell that cooperates with other lymphocytes via direct contact or cytokine release to initiate a variety of immune functions.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000492> "CALOHA:TS-1146")
