# Class: <http://purl.obolibrary.org/obo/CL_0000826> (pro-B cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0781735149") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:12633665") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16551251") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18432934") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000826> "A progenitor cell of the B cell lineage, with some lineage specific activity such as early stages of recombination of B cell receptor genes, but not yet fully committed to the B cell lineage until the expression of PAX5 occurs.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:17582343") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000826> "pre-pro B cell")
