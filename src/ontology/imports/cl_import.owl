# Class: <http://purl.obolibrary.org/obo/CL_1000347> (colonocyte)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16870803") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:23821742") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34497389") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_1000347> "An enterocyte (absorptive epithelial cell) of the colonic epithelium, characterized by a columnar shape. This cell is responsible for the absorption, transport, and metabolization of short-chain fatty acids (SCFAs) produced by gut bacteria, as well as the transport and absorption of water and electrolytes.")
