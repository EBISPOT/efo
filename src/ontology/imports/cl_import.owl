# Class: <http://purl.obolibrary.org/obo/CL_4052006> (intestinal enteroendocrine progenitor)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31756561") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32531023") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35913117") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:38260422") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "doi:/10.1038/s41467-021-27901-5") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052006> "An epithelial cell that is part of the crypt of Lieberkuhn, originating from intestinal stem cells and giving rise to enteroendocrine cells (EECs). In mouse and human, this cell can be characterized by the expression of Neurog3, and has the ability to proliferate and differentiate into multiple EEC subtypes. Its proliferative potential contributes to crypt growth, distinguishing it from fully differentiated EECs.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052006> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052006> "2024-09-20T12:13:26Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31756561") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/OMO_0003000>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_4052006> "EEC Progenitor")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:25670791") rdfs:comment <http://purl.obolibrary.org/obo/CL_4052006> "The EEC progenitor is also present in other organisms; for example, flies have EEC progenitors but lack intestinal crypts and do not express the same markers. Instead, they are Dl+ and Pros+.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052006> "intestinal enteroendocrine progenitor")
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052006> <http://purl.obolibrary.org/obo/CL_0002563>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052006> <http://purl.obolibrary.org/obo/CL_0011026>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052006> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0011184>))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052006> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/CL_0002250>))

# Class: <http://purl.obolibrary.org/obo/CL_4052014> (pancreatic islet capillary endothelial cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16607697") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:27124642") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:28396983") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:33200981") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052014> "A capillary endothelial cell that is part of islet of Langerhans, characterized by a high density of fenestrations —approximately ten times greater than those in exocrine pancreatic capillaries. These fenestrations facilitate efficient hormone exchange, which is essential for maintaining glucose homeostasis. The cell's structure and function are regulated by the local production of vascular endothelial growth factor-A (VEGF-A), which maintains its fenestrated architecture.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052014> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052014> "2024-09-30T14:36:12Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16607697") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:28396983") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_4052014> "islet endothelial cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16607697") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_4052014> "pancreatic islet endothelial cell")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052014> "pancreatic islet capillary endothelial cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052014> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002144> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0000006>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052014> <http://purl.obolibrary.org/obo/CL_0000666>)
