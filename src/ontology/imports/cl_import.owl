# Class: <http://purl.obolibrary.org/obo/CL_0000860> (classical monocyte)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GO_REF:0000031") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:16322748") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18303997") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20628149") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20870168") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000860> "A monocyte that responds rapidly to microbial stimuli by secreting cytokines and antimicrobial factors and which is characterized by high expression of CCR2 in both rodents and humans, negative for the lineage markers CD3, CD19, and CD20, and of larger size than non-classical monocytes.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000860> "inflammatory monocyte")
