# Class: <http://purl.obolibrary.org/obo/CL_0000043> (mature basophil)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0721601464") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18466030") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:19231594") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20837449") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.cap.org") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000043> "A fully differentiated basophil, a granular leukocyte with an irregularly shaped, pale-staining nucleus that is partially constricted into two lobes, and with cytoplasm that contains coarse granules of variable size. Basophils contain vasoactive amines such as histamine and serotonin, which are released on appropriate stimulation.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000043> "polymorphonuclear leucocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000043> "polymorphonuclear leukocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000043> "BTO:0001026")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000043> "CALOHA:TS-0688")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000043> "mature basophil leucocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000043> "mature basophil leukocyte")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000043> "Mature basophils are also capable of producing IL-3, IL-5, IL-6, IL-8, IL-13, IL-25, CCL22, tslp, vegf, and LTC4.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000043> "mature basophil")
