AnnotationAssertion(Annotation(rdfs:label "CD1c-positive myeloid dendritic cell on CELLxGENE CellGuide") rdfs:seeAlso <http://purl.obolibrary.org/obo/CL_0002399> "https://cellxgene.cziscience.com/cellguide/CL_0002399")
