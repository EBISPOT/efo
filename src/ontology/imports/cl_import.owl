AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000098> "The term \"neuroepithelial cell\" is used to describe both this cell type and neurecto-epithelial cell (CL:0000710).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000098> "sensory epithelial cell")
