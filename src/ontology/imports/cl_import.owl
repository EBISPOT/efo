AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000860> "Markers: CCR2+CXCCR1<low> (human, mouse, rat).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000860> "classical monocyte")
