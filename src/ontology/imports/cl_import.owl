# Class: <http://purl.obolibrary.org/obo/CL_0000831> (mast cell progenitor)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMCID:PMC1183570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMCID:PMC1312421") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:8629001") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:9354811") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.copewithcytokines.de") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000831> "A progenitor cell of the mast cell lineage. Markers for this cell are FceRIa-low, CD117-positive, CD9-positive, T1/ST2-positive, SCA1-negative, and lineage-negative.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000831> "MCP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_0000831> "CFU-MC")
