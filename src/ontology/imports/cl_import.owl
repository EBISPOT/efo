# Class: <http://purl.obolibrary.org/obo/CL_4052022> (fallopian tube smooth muscle cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31183831") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31613440") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052022> "A smooth muscle cell that is part of the fallopian tube. This cell is responsible for peristaltic contractions that facilitate gamete and embryo transport, fluid mixing, and embryo admission to the uterus.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052022> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052022> "2024-10-21T12:16:54Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31613440") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_4052022> "oviduct smooth muscle cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:31613440") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4052022> "uterine tube smooth muscle cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18621753") rdfs:comment <http://purl.obolibrary.org/obo/CL_4052022> "The fallopian tube smooth muscle cell in the human contracts dynamically in response to hormones and signaling molecules. Prostaglandins, particularly PGF2α and PGE2, have been shown to increase muscular contractions, while progesterone, levonorgestrel, mifepristone, oxytocin, and human chorionic gonadotropin (hCG) decrease them. These contractile responses are crucial for regulating gamete and embryo transport through the fallopian tube.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052022> "fallopian tube smooth muscle cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052022> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0000192> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0003889>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052022> <http://purl.obolibrary.org/obo/CL_0000192>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052022> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0003889>))

# Class: <http://purl.obolibrary.org/obo/CL_4052028> (uterine natural killer cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35720413") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:39198675") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Uterine_natural_killer_cells") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052028> "A natural killer cell that is part of the uterus, specifically within the endometrium during the non-pregnant state and in the decidua during pregnancy. This cell exhibits dynamic changes in frequency throughout the menstrual cycle, with lower levels during menstruation and a significant increase during the mid-secretory phase and early pregnancy.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052028> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052028> "2024-11-15T10:12:40Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:35720413") <http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym> <http://purl.obolibrary.org/obo/CL_4052028> "endometrial natural killer cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:39198675") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/OMO_0003000>) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_4052028> "uNK cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_4052028> <http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052028> "uterine natural killer cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052028> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0000623> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0000995>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052028> <http://purl.obolibrary.org/obo/CL_0000623>)
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052028> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0000995>))

# Class: <http://purl.obolibrary.org/obo/CL_4052035> (tuft cell of pancreatic duct)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:30904566") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32717220") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052035> "A tuft cell that is part of the epithelium of pancreatic duct. Present in humans and rats, this cell is absent in the murine pancreas under normal conditions but emerges during acinar-to-ductal metaplasia triggered by injury, inflammation, or oncogenic mutations. It modulates the immune response and protects against pancreatic ductal adenocarcinoma progression by producing suppressive eicosanoids, such as prostaglandin D2. A tuft cell in the pancreatic duct highly expresses the transcription factor POU2F3, which is essential for its development and presence.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052035> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052035> "2025-01-16T11:50:08Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:9749964") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4052035> "pancreatic brush cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32717220") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_4052035> "pancreatic tuft cell")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052035> "tuft cell of pancreatic duct")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052035> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002204> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0009970>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052035> <http://purl.obolibrary.org/obo/CL_0000068>)
