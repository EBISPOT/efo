# Class: <http://purl.obolibrary.org/obo/CL_4052016> (pituitary gland capillary endothelial cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:10810312") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32910242") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_4052016> "A capillary endothelial cell that is part of the pituitary gland. This cell is characterized by its fenestrated structure which facilitates the efficient transport of hormones and other signaling molecules, essential for endocrine signalling.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/CL_4052016> <https://orcid.org/0009-0000-8480-9277>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/CL_4052016> "2024-09-30T15:31:45Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:4899902") rdfs:comment <http://purl.obolibrary.org/obo/CL_4052016> "In the anterior pituitary gland of rats, capillary endothelial cells are distinguished by numerous fenestrations, which are covered by a single-layered diaphragm. The diaphragm features a dense ring-like structure.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_4052016> "pituitary gland capillary endothelial cell")
EquivalentClasses(<http://purl.obolibrary.org/obo/CL_4052016> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002144> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/UBERON_0000007>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_4052016> <http://purl.obolibrary.org/obo/CL_0000666>)
