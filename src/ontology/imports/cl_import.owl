AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000785> <http://purl.obolibrary.org/obo/cl#cellxgene_subset>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000785> "Mature B cells are also reportedly CD10-negative, CD19-positive, CD22-positive, CD34-negative, CD48-positive, CD79a-positive, CD84-positive, CD127-negative, CD352-positive, RAG-negative, TdT-negative, Vpre-B-negative, and pre-BCR-negative. Transcription factors expressed: Pax5-positive.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000785> "mature B cell")
AnnotationAssertion(Annotation(rdfs:label "mature B cell on CELLxGENE CellGuide") rdfs:seeAlso <http://purl.obolibrary.org/obo/CL_0000785> "https://cellxgene.cziscience.com/cellguide/CL_0000785")
