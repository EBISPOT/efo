# Class: <http://purl.obolibrary.org/obo/CL_0000771> (eosinophil)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:amm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:tfm") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0721601464") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMCID:PMC2626675") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:10914487") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:1662676") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000771> "Any of the immature or mature forms of a granular leukocyte with a nucleus that usually has two lobes connected by one or more slender threads of chromatin, and cytoplasm containing coarse, round granules that are uniform in size and which can be stained by the dye eosin. Eosinophils are CD9-positive, CD191-positive, and CD193-positive.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "polymorphonuclear leucocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "polymorphonuclear leukocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000771> "BTO:0000399")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000771> "CALOHA:TS-0279")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000771> "FMA:62861")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CL_0000771> "MESH:D004804")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "eosinocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "eosinophilic granulocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "eosinophilic leucocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000771> "eosinophilic leukocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000771> <http://purl.obolibrary.org/obo/cl#blood_and_immune_upper_slim>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000771> <http://purl.obolibrary.org/obo/cl#cellxgene_subset>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000771> <http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000771> "Eosinophils are also CD14-negative, CD32-positive, CD44-positive, CD48-positive, CD69-positive, CD192-negative, MBP1-positive, MBP2-positive, TLR2-negative, TLR4-negative, and lineage-negative (B220, CD2, CD14, CD19, CD56, CD71, CD117, CD123, CD235a (glycophorin A), and TER119). The cytokines IL-3, IL-5, and GM-CSF are involved in their development and differentiation. Usually considered CD16-negative, CD16 is observed on eosinophilic metamyelocyte.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000771> "eosinophil")
AnnotationAssertion(Annotation(rdfs:label "eosinophil on CELLxGENE CellGuide") rdfs:seeAlso <http://purl.obolibrary.org/obo/CL_0000771> "https://cellxgene.cziscience.com/cellguide/CL_0000771")
