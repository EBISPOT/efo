AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0020031> "exhausted CD8-positive T cell")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0020031> "CD8-positive exhausted alpha-beta T cell")
