# Class: <http://purl.obolibrary.org/obo/CL_0000825> (pro-NK cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:pam") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GO_REF:0000031") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:11532393") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:12457618") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:15032583") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:15766674") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000825> "A lymphoid progenitor cell that is committed to the natural killer cell lineage, expressing CD122 (IL-15) receptor, but lacking many of the phenotypic characteristics of later stages of natural killer cell development such as expression of NK activating and inhibitory molecules. In human this cell has the phenotype CD34-positive, CD45RA-positive, CD10-positive, CD117-negative, and CD161 negative.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:12457618") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:15032583") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:15766674") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000825> "NKP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000825> "natural killer cell progenitor")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000825> "pro-natural killer cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:11532393") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_0000825> "null cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:11532393") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/CL_0000825> "preNK cell")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000825> "Most markers only described for human pro NK cells.")
