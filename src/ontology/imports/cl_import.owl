# Class: <http://purl.obolibrary.org/obo/CL_0000819> (B-1 B cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GO_REF:0000031") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:11861604") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20933013") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:21220451") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://en.wikipedia.org/wiki/B-1_cell") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000819> "A B cell of distinct lineage and surface marker expression. B-1 B cells are thought to be the primary source of natural IgM immunoglobulin, that is, IgM produced in large quantities without prior antigenic stimulation and generally reactive against various microorganisms, as well as the source of T-independent IgA immunoglobulin in the mucosal areas. These cells are CD43-positive.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B-1 B lymphocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B-1 B-cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B-1 B-lymphocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B-1 cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B1 B cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B1 B lymphocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B1 B-cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B1 B-lymphocyte")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000819> "B1 cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/CL_0000819> <http://purl.obolibrary.org/obo/cl#cellxgene_subset>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000819> "There are small numbers of B-1 cells found in the lymph nodes and spleen, while larger numbers can be found in the peritoneal and pleural cavities. B-1 B cells are reportedly CD11b-positive, CD20-positive, CD21-positive, CD27-positive, CD44-positive, CD45RB-positive, CD48-positive, CD70-negative, CD150-positive, CD244-negative, CD352-positive, sIgM-positive, and sIgD-low.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000819> "B-1 B cell")
AnnotationAssertion(Annotation(rdfs:label "B-1 B cell on CELLxGENE CellGuide") rdfs:seeAlso <http://purl.obolibrary.org/obo/CL_0000819> "https://cellxgene.cziscience.com/cellguide/CL_0000819")
