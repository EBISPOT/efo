EquivalentClasses(<http://purl.obolibrary.org/obo/CL_0002496> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/CL_0002419> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0001025> <http://purl.obolibrary.org/obo/UBERON_0000483>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002215> <http://purl.obolibrary.org/obo/GO_0002385>)))
SubClassOf(<http://purl.obolibrary.org/obo/CL_0002496> <http://purl.obolibrary.org/obo/CL_0002419>)
