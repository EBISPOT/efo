AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/CL_0000560> "stab cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000560> "rod neutrophil")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/CL_0000560> "Found in the Band 1 fraction.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000560> "band form neutrophil")
