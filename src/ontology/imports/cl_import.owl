# Class: <http://purl.obolibrary.org/obo/CL_0000788> (naive B cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:add") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:dsd") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:rhs") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GO_REF:0000031") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0781765196") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:19447676") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20081059") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20839338") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:20933013") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:22343568") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000788> "A naive B cell is a mature B cell that has the phenotype surface IgD-positive, surface IgM-positive, CD20-positive, CD27-negative and that has not yet been activated by antigen in the periphery.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000788> "naive B lymphocyte")
