AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0702022918") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0702024783") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000647> "multinucleate giant cell")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0702022918") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0702024783") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/CL_0000647> "syncytial giant cell")
