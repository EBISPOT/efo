# Class: <http://purl.obolibrary.org/obo/CL_0000112> (columnar neuron)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34696823") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:37608556") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/CL_0000112> "A neuron of the invertebrate central nervous system. This neuron innervates the central complex (CX) of an invertebrate brain and it forms columnar patterns with its dendrites. It is involved in navigation and spatial processing.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:18837039") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:32374034") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:34696823") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:37608556") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "PMID:9153131") rdfs:comment <http://purl.obolibrary.org/obo/CL_0000112> "Columnar neurons have been widely studied in Diptera, locusts, honey bees and other insects. In the mammalian brain, a \"columnar organisation\" is referred to neurons of the neocortex, however these differ from columnar neurons which are found in the insects central nervous system.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/CL_0000112> "columnar neuron")
SubClassOf(<http://purl.obolibrary.org/obo/CL_0000112> <http://purl.obolibrary.org/obo/CL_0000028>)
