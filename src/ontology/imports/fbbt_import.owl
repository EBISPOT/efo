SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110921> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0013002> <http://purl.obolibrary.org/obo/FBbt_00051067>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00110922> (larval protocerebrum-innervating Hugin neuron)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0188215") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0200884") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0234450") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00110922> "Cholinergic larval neuron that expresses Hugin (FBgn0028374) and that arborizes in the protocerebrum (Bader et al., 2007; Schlegel et al., 2016). This neuron arborizes in the ipsilateral or both hemispheres of the protocerebrum and the ventrolateral region of the esophagus foramen. As well as receiving inputs in the subesophageal ganglion, they also have outputs in the subesophageal ganglion. There are four of these neurons per hemisphere and they form reciprocal ipsilateral connections amongst themselves and also have outputs to insulin secreting cells of the pars intercerebralis (Schlegel et al., 2016). Much of their synaptic input is from sensory neurons (Schlegel et al., 2016).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00110922> <https://orcid.org/0000-0001-5948-3092>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00110922> "2014-08-14T17:55:17Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00110922> "VFB:FBbt_00110922")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0234450") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110922> "hugin-PC")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110922> "larval Hugin neuron of the protocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110922> "larval hugin cell of the protocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00110922> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00110922> "FBbt:00110922")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00110922> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00110922> "Synapsing identified in full L1 VNC EM volume - all hugin-PC cells have presynaptic connections to multiple insulin cells and up to 39 percent of synaptic input is from sensory neurons (Schlegel et al., 2016).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00110922> "larval protocerebrum-innervating Hugin neuron")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110922> <http://purl.obolibrary.org/obo/FBbt_00058215>)
