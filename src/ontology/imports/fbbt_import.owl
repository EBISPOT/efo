SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00003215> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00049627>))
