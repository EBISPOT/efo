# Class: <http://purl.obolibrary.org/obo/FBbt_00003143> (adult hindgut)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0007735") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064792") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0075527") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0228784") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003143> "Posterior part of the of the adult alimentary canal, extending from the posterior end of the midgut, where the Malpighian tubules meet, to the rectum, including the rectal pouch and rectal papillae (Miller, 1950; Skaer, 1993; Demerec, 1994). It has a characteristic loop morphology that forms independently of the rotation of the genitalia (Gonzalez-Morales et al., 2015).")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0007735") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00003143> "adult intestine")
