# Class: <http://purl.obolibrary.org/obo/FBbt_00005804> (hypocerebral ganglion)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0239029") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005804> "Small ganglion of the stomatogastric nervous system. It is located between the two brain hemispheres. In the adult, it is part of the ring gland.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00005804> "VFB:FBbt_00005804")
