AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00005794> "Other cell types are known to exist, but have yet not been identified (personal communication by Helen Skaer).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00005794> "specialized Malpighian tubule cell")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005794> <http://purl.obolibrary.org/obo/FBbt_00100318>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005794> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00005786>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00005795> (Malpighian tubule tip cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0050653") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0075100") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0222532") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005795> "Cell at the distal tip of each Malpighian tubule. It is involved in tube elongation in embryogenesis by stimulating cell proliferation in neighboring cells and in positioning the tubules.")
