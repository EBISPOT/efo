# Class: <http://purl.obolibrary.org/obo/FBbt_00004911> (oviduct)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0017075") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0226663") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0253444") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00004911> "Duct of the female reproductive tract that connects the ovaries to the uterus (Hildreth, 1965; McQueen et al., 2022). The oviduct consists of two lateral oviducts (each connected to an ovary) and one common oviduct, to which the lateral oviducts connect, and which itself connects to the uterus (Hildreth, 1965; McQueen et al., 2022).")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0226663") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00004911> "female internal reproductive tract")
