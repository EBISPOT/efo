AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBim0000051") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBim0000052") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBim0000053") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0034081") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064787") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003037> "Tracheal system of the adult. It retains the same basic pattern of the larval tracheal system, except for the presence of air sacs and the disappearance of the last tracheal segment. It is composed of nine tracheal metameres.")
