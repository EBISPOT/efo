# Class: <http://purl.obolibrary.org/obo/FBbt_00001704> (embryonic/larval fat body)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0017184") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0238315") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00001704> "Fully developed fat body of the late embryo (from stage 17 onward) or the larva. It is a bilateral, multilobed organ that extends the length of the insect (Butterworth et al., 1965). It is one cell thick and between one and ten cells wide (Butterworth et al., 1965). Large holes and clefts form during stage 17, giving the fat body its definitive larval form (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasAlternativeId> <http://purl.obolibrary.org/obo/FBbt_00001704> "FBbt:00005711")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0238315") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001704> "larval fat body")
