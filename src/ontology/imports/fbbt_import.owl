# Class: <http://purl.obolibrary.org/obo/FBbt_00045032> (superior intermediate protocerebrum)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0211016") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "VFB_vol:00045032") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00045032> "A small synaptic neuropil domain of the adult located around and posterior to the mushroom body vertical lobe, in front of the superior fiber system and above the superior clamp. This domain is rich in loose fibers that project from the anterior optic tubercle in a medial-posterior direction. It also houses the arborizations of many neurons that connect with the vertical lobes.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0229653") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "LPC")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00045032> "VFB:FBbt_00045032")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "SIP")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "DLP")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "FSPP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00045032> "fly_anatomy.ontology")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "impr")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00045032> "smpr")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00045032> "FBbt:00045032")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00045032> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00045032> "The SIP encompasses the ring neuropil, which corresponds to the terminals of the mlALT neurons, which wrap around the distal tip region of the mushroom body vertical lobe (Ito et al., 2014). Different regions of the SIP correspond to the subdivisions of the smpr and impr (Otsuna and Ito, 2006). The anterior and posterior regions of the superior SIP match part of smpr; the anterior and posterior regions of the inferior SIP match part of impr (Ito et al., 2014). The SIP correspond to the medial part of the dorsolateral protocerebrum (DLP) and the frontal superpeduncular protocerebrum (FSPP) of Chiang et al. (2011).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00045032> "superior intermediate protocerebrum")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00045032> <http://purl.obolibrary.org/obo/FBbt_00040007>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00045032> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00007145>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00045032> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00045030>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00045032> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00007064>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00045037> (adult crepine)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0211016") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "VFB_vol:00045037") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00045037> "A thin, bilaterally paired synaptic neuropil domain that wraps around the medial lobe of the mushroom body. Many neurons in this domain enter the lobes to form extensive connections with Kenyon cell fibers.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00045037> "VFB:FBbt_00045037")
