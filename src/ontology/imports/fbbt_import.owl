# Class: <http://purl.obolibrary.org/obo/FBbt_00000126> (mesoderm)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0155831") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00000126> "Middle germ layer of the embryo (between ectoderm and endoderm) following gastrulation (Campos-Ortega and Hartenstein, 1997). Shortly after its formation, its cells undergo mitosis and it loses its regular epithelial architecture (Campos-Ortega and Hartenstein, 1997). In stage 9 it reorganizes into a regular monolayer of cuboidal cells that lines the ectoderm (Campos-Ortega and Hartenstein, 1997). At the end of stage 10 further cell divisions disrupt this structure and its cells reform into two layers in stage 11 (Campos-Ortega and Hartenstein, 1997). It finally splits up into separate cell masses in late stage 11 (Campos-Ortega and Hartenstein, 1997). Its derivatives include the muscles, heart and fat body (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00000126> "UBERON:0000926")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00000126> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00000126> "FBbt:00000126")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00000126> <http://purl.obolibrary.org/obo/fbbt#FB_gloss>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00000126> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00000126> "mesoderm")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00000126> <http://purl.obolibrary.org/obo/FBbt_00000110>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00000126> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00000104>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00000126> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002203> <http://purl.obolibrary.org/obo/FBbt_00025998>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00000127> (head mesoderm)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064803") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0190261") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00000127> "Anterior region of mesoderm that forms a vertical plate beside the anterior midgut rudiment (Campos Ortega and Hartenstein, 1997). After its initial ingression during ventral furrow formation, it continues to recruit cells from the surface of the embryo until the end of stage 10 (Campos Ortega and Hartenstein, 1997). It gives rise to the pharyngeal musculature, hemocytes, the corpus cardiacum and the visceral muscle of the esophagus (Campos Ortega and Hartenstein, 1997; de Velasco et al., 2006).")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064803") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00000127> "hms")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00000127> "procephalic mesoderm")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00000127> "fly_anatomy.ontology")
