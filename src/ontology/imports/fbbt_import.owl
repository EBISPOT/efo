# Class: <http://purl.obolibrary.org/obo/FBbt_00004011> (insulin secreting cell of pars intercerebralis)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0134726") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0136823") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0149175") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0151837") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0184236") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193772") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212696") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224974") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0261099") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "doi:10.7554/eLife.102684.1") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00004011> "Insulin-producing neuron with a cell body in the pars intercerebralis. These cells coexpress the genes Insulin-like peptide (Ilp) 2, Ilp3 and Ilp5 (Reinhard et al., 2024). There are approximately 7-9 of these cells per hemisphere and they fasciculate with the nervus corporis cardiaci (McKim et al., 2024).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00004011> "IPC")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00004011> "dorsomedial neurosecretory cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00004011> "VFB:FBbt_00004011")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00004011> "insulin producing cell of brain")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0261099") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00004011> "m-NSC DILP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00004011> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00004011> "FBbt:00004011")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00004011> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00004011> "Insulin-producing cells are found amongst the median neurosecretory cells, but not all mNSCs are IPCs (FBrf0212696), despite misleading phrasing in some articles (e.g. FBrf0184236).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00004011> "insulin secreting cell of pars intercerebralis")
