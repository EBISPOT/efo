AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBim0000051") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBim0000052") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0007735") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0034081") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003109> "A ventrally located air sac of the metathorax. It arises from the lateral trunk and extends ventrally into the base of the metathoracic leg. The metathoracic (posterior thoracic) spiracle opens into this air sac.")
