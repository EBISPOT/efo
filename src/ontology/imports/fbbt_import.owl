SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110922> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0013003> <http://purl.obolibrary.org/obo/FBbt_00100138>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110922> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0013009> <http://purl.obolibrary.org/obo/FBbt_00110035>))

