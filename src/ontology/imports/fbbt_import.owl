SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110636> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00003624>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00110636> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00001920>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00110638> (adult supraesophageal zone)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00110638> "Neuropil mass above the esophagus in the adult brain. It is part of the cerebral ganglion.")
