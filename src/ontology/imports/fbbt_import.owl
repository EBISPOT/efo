AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00045039> "pimpr")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00045039> "posterior inferior protocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00045039> "VFB:FBbt_00045039")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00045039> "ATL")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00045039> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00045039> "FBbt:00045039")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00045039> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00045039> "The antler corresponds to part of the medial part of the pimpr of Otsuna and Ito (2006) and to the dorsal part of the caudalcentral protocerebrum (CCP) of Chiang et al. (2011) and to part of the posterior inferior protocerebrum (Ito et al., 2014).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00045039> "antler")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00045039> <http://purl.obolibrary.org/obo/FBbt_00040007>)
