SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00040051> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00110639>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00040051> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00007720>))

