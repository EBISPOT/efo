# Class: <http://purl.obolibrary.org/obo/FBbt_00000424> (embryonic/larval posterior spiracle)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0034081") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064787") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00000424> "The main spiracle of the larva on the dorsal side of the eight (last) abdominal segment. During the first larval instar it is the only functional spiracle of the larva. A bilateral pair of these spiracles is housed in a bilateral pair of integumentary specializations - the stigmatophores. Each consists of a plate containing the spiracular openings. These connect to a spiracular chamber which in turn connects to the posterior end of the dorsal trunk. In the second instar there are three ovoid openings on the stigmatic plate and four alternating tufts of slightly branched hairs. In the third instar, the spiracles are somewhat larger and the hairs more markedly branched.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasAlternativeId> <http://purl.obolibrary.org/obo/FBbt_00000424> "FBbt:00005604")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00000424> "larval posterior spiracle")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00000424> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00000424> "FBbt:00000424")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00000424> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00000424> "embryonic/larval posterior spiracle")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00000424> <http://purl.obolibrary.org/obo/FBbt_00000406>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00000424> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00000425>))
