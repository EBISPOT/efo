# Class: <http://purl.obolibrary.org/obo/FBbt_00007295> (larval ventral sensory cluster group)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0108300") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0183734") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00007295> "Group of sense organs, and the somas and dendrites of sensory neurons, located ventrally in a larval segment (Campos-Ortega and Hartenstein, 1997). It lies outside the ventrolateral and ventral muscles, beneath the ventral insertion of the lateral transverse muscles (Campos-Ortega and Hartenstein, 1997). It can be divided into two smaller clusters (ventral and ventral'), with the axons of neurons of each cluster following a different branch of the segmental nerve (Willams and Shepherd, 1999). The pattern of sense organs and neurons is highly similar in segments A1-7, and slightly modified in the thoracic segments (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00007295> <https://orcid.org/0000-0002-7073-9172>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00007295> "2008-11-18T01:31:32Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00007295> "ventral group of sensory organs")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007295> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007295> "embryonic/larval thoracic/abdominal ventral sensory cluster")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007295> "larval thoracic/abdominal ventral sensory cluster")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007295> "FBbt:00007295")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00007295> "Terminal (A8-10) segments have substantially different morphology, such that no 'ventral cluster' is present as seen in more anterior segments.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00007295> "larval ventral sensory cluster group")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007295> <http://purl.obolibrary.org/obo/FBbt_00007316>)
