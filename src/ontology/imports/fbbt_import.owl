# Class: <http://purl.obolibrary.org/obo/FBbt_00040051> (prow)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0237252") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "VFB_vol:00040051") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00040051> "Anteriormost and superior synaptic neuropil domain below the esophagus (Ito et al., 2014). It lies inferior and anterior to the opening of the esophageal foramen (Ito et al., 2014). It houses the superior pharyngeal sensory center (SPhS), containing the terminals of peripheral axons from the pharyngeal nerve (Ito et al., 2014). It forms the ventral part of the tritocerebrum, developing from the ventromedial domain of the larval tritocerebrum (Hartenstein et al., 2018).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00040051> <https://orcid.org/0000-0002-7073-9172>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00040051> "2009-08-13T04:55:04Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00040051> "PENPa")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00040051> "anterior periesophageal neuropils")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00040051> "VFB:FBbt_00040051")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00040051> "PRW")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0237252") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00040051> "TRv")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0237252") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00040051> "ventral tritocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00040051> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00040051> "FBbt:00040051")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00040051> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00040051> "The name 'prow' was taken from the anterior-most part of the hull of a boat. It is part of the ventral cerebral ganglion, which is included in the adult subesophageal zone (old subesophageal ganglion, or SOG) (Ito et al., 2014). The prow also corresponds to the dorsoanterior part of the subesophageal ganglion (SOG) of Chiang et al. (2011) and to the part of the anterior periesophageal neuropils (Ito et al., 2014).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00040051> "prow")
