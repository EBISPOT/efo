AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym> <http://purl.obolibrary.org/obo/FBbt_00007707> "dorsolateral subdivision of ventral nerve cord")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007707> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007707> "FBbt:00007707")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00007707> "dorsolateral domain of larval central nervous system")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007707> <http://purl.obolibrary.org/obo/FBbt_00007702>)

