# Class: <http://purl.obolibrary.org/obo/FBbt_00005319> (stage 7 embryo)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://orcid.org/0000-0002-7073-9172") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005319> "Stage 7 begins when the pole cells have adopted a dorsal (horizontal) position at the posterior. Invagination of the anterior and posterior midgut and hindgut follows. The 'discoid plate' carrying the pole cells forms a pocket. Transverse furrows (dorsal folds) form on the dorsal surface. This stage ends when the anterior wall of the amnioproctodeal invagination starts moving anteriorly and the pole cells are no longer visible externally. Duration at 25 degrees C: approximately 10 minutes (180-190 minutes after egg laying).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00005319> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00005319> "FBbt:00005319")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00005319> <http://purl.obolibrary.org/obo/fbbt#deprecated>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00005319> "DEPRECATION WARNING.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00005319> "stage 7 embryo")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005319> <http://purl.obolibrary.org/obo/FBbt_00005317>)
