# Class: <http://purl.obolibrary.org/obo/FBbt_00003133> (crop)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064792") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0075527") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003133> "Pedunculate sac evaginating from the adult foregut just before it meets the midgut. It is a bi-lobed structure capable of considerable extension, whose function is the storage of ingested liquid food.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0007735") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00003133> "pedunculate crop")
