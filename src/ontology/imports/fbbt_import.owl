# Class: <http://purl.obolibrary.org/obo/FBbt_00005322> (stage 8 embryo)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://orcid.org/0000-0002-7073-9172") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005322> "Stage 8 starts with the rapid phase of germ band extension and ends with the beginning of mesodermal segmentation. By the end of this stage germ band extension has progressed to the point where the proctodeal opening is at about 60% egg length and the dorsal folds (transverse furrows) are no longer visible. Duration at 25 degrees C: approximately 30 minutes (190-220 minutes after egg laying).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00005322> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00005322> "FBbt:00005322")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00005322> <http://purl.obolibrary.org/obo/fbbt#deprecated>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00005322> "DEPRECATION WARNING.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00005322> "stage 8 embryo")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005322> <http://purl.obolibrary.org/obo/FBbt_00005317>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005322> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00005319>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00005326> (stomodeal invagination)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005326> "Infolding of the anteroventral embryo that arises during stage 10 (Campos-Ortega and Hartenstein, 1997). Its formation begins when cells surrounding the stomodeal anlage, which consists of a plate of tall cylindrical cells just prior to invagination, divide synchronously (Campos-Ortega and Hartenstein, 1997). The invaginated cells divide immediately afterwards, forming a monolayered epithelium (Campos-Ortega and Hartenstein, 1997). It is initially oriented perpendicular to the horizontal plane, but progressively bends towards the ventral plane (Campos-Ortega and Hartenstein, 1997). It grows caudally by cell divisions and incorporation of neighboring ectodermal cells (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00005326> "stomodeum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00005326> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00005326> "anterior midgut invagination")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00005326> "FBbt:00005326")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00005326> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00005326> "stomodeal invagination")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00005326> <http://purl.obolibrary.org/obo/FBbt_00100313>)
