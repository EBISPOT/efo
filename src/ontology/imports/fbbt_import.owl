# Class: <http://purl.obolibrary.org/obo/FBbt_00001370> (stage 1 neuroblast)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0055900") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0073294") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0076117") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0112030") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00001370> "The first neuroblast subpopulation delaminating from the ventral neurectoderm towards the end of the second mesodermal cell division, shortly after gastrulation (Hartenstein and Campos-Ortega, 1984). These neuroblasts are generally arranged in two fairly regular longitudinal rows (the medial and lateral longitudinal rows), with a few cells scattered in an intermediate row. Doe (1992) defines the end of S1 as being early embryonic stage 9 following the development of NB3-2.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00001370> "VFB:FBbt_00001370")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00001370> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00001370> "S1 neuroblast")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00001370> "SI neuroblast")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00001370> "FBbt:00001370")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00001370> <http://purl.obolibrary.org/obo/fbbt#EmbDevSlim>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00001370> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00001370> "Figure 7 of Hartenstein and Campos-Ortega, (1984), graphically depicts the pattern formed by the population of neuroblasts for the left half of the germ band.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00001370> "stage 1 neuroblast")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00001370> <http://purl.obolibrary.org/obo/FBbt_00005146>)

# Class: <http://purl.obolibrary.org/obo/FBbt_00001376> (neuroblast NB5-2)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0055900") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0073294") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0076117") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0084809") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0112030") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0180161") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0221210") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0228122") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0231327") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0232096") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00001376> "Neuroblast that delaminates at stage 1 in the medial column (Hartenstein and Campos-Ortega, 1984). It generates a single motorneuron innervating muscle 12 via the SNb and a large number of interneurons, which constitute most of the posterior commissure (Schmid et al., 1999). In the embryo, one of these cells can be found in each hemisegment from S2-A8 (Birkholz et al., 2013; Urbach et al., 2016). In the larva, it resumes proliferation in at least S3-A7 (Lacin and Truman, 2016). The neurons that develop from this neuroblast after larval hatching form postembryonic lineage 6 (Lacin and Truman, 2016).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00001376> "VFB:FBbt_00001376")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0209606") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "NB 6")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0231327") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "lineage 6 neuroblast")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "lineage NB5-2 neuroblast")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0228122") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0231327") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#SECONDARY_VNC_LINEAGE>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "neuroblast 6")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0228122") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0231327") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#PRIMARY_VNC_LINEAGE>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "neuroblast NB5-2")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0047815") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "neuroblast vm")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0047815") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "ventromedial neuroblast")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00001376> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00001376> "medial SI neuroblast NB 5-2")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00001376> "FBbt:00001376")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00001376> <http://purl.obolibrary.org/obo/fbbt#EmbDevSlim>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00001376> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00001376> "This is equivalent to the 'ventromedial neuroblast' of Truman and Bate (1988) - FBrf0047815, due to existence in A2-7 and its relatively medial location (Lacin and Truman, 2016). Lacin and Truman (2016) do not show data for neuromeres anterior to S3 (labial) or posterior to A7.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00001376> "neuroblast NB5-2")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00001376> <http://purl.obolibrary.org/obo/FBbt_00001370>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00001376> <http://purl.obolibrary.org/obo/FBbt_00051362>)

