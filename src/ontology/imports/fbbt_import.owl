# Class: <http://purl.obolibrary.org/obo/FBbt_00110035> (larval insulin secreting cell of pars intercerebralis)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0134726") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0136823") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0149175") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0151837") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193772") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0210278") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0234450") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0249161") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00110035> "Insulin-producing neurosecretory cell with its cell body in the larval pars intercerebralis (Ikeya et al., 2002). The same cells express Ilp2, Ilp3 and Ilp5 mRNA with different temporal profiles (Ikeya et al., 2002). An axonal branch projects to the contralateral side, looping posteriorly then anteriorly, and entering the nervus corporis cardiaci (Siegmund and Korge, 2001; Huckesfeld et al., 2021). This branch projects to the ring gland, where it has peptide release sites in the corpus cardiacum and along the aorta (Siegmund and Korge, 2001; Rulifson et al., 2002; Huckesfeld et al., 2021). Dendrites extend ventrally, close to the midline, reaching the subesophageal zone, and laterally, into the lateral protocerebrum (Siegmund and Korge, 2001; Rulifson et al., 2002; Huckesfeld et al., 2021). It receives synaptic input from hugin neurons of the protocerebrum (Schlegel et al., 2016). There are seven of these cells in each hemisphere (Cao and Brown, 2001; Rulifson et al., 2002; Ikeya et al., 2002; Park et al., 2008).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00110035> <https://orcid.org/0000-0001-5948-3092>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00110035> "2012-03-02T12:32:50Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0149175") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "IPC cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "larval dorsomedial neurosecretory cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00110035> "VFB:FBbt_00110035")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0210278") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "PI 1-7")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0134726") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "larval corpus cardiacum and aorta innervating neurosecretory neuron of the pars intercerebralis 1")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0134726") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0249161") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "larval corpus cardiacum innervating neuron CC/A-PI 1")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0149175") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "larval insulin producing cell of brain")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "doi:10.7554/eLife.102684.1") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110035> "larval mNSC DILP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00110035> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00110035> "FBbt:00110035")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00110035> "Insulin-producing cells are found amongst the median neurosecretory cells, but not all mNSCs are IPCs (FBrf0212696), despite misleading phrasing in some articles (e.g. FBrf0184236). Synapsing identified in full L1 VNC EM volume - all insulin cells have connections from multiple hugin-PC cells (Schlegel et al., 2016).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00110035> "larval insulin secreting cell of pars intercerebralis")
EquivalentClasses(<http://purl.obolibrary.org/obo/FBbt_00110035> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/FBbt_00004011> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002131> <http://purl.obolibrary.org/obo/FBbt_00001727>)))
