# Class: <http://purl.obolibrary.org/obo/FBbt_00049277> (larval ring gland)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0064803") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0179777") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0194938") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0239029") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00049277> "A closely associated cluster of three neuroendocrine glands of the late embryo or larva, located anterior to the brain and dorsal to the esophagus (de Velasco et al., 2004). It consists of the corpus cardiacum posteroventrally (closest to the brain), the prothoracic gland laterally (forming most of the ring gland) and the corpus allatum anterodorsally (furthest from the brain) (de Velasco et al., 2004). It is innervated by neurons of the nerve of the corpus cardiacum and the aorta passes through it (de Velasco et al., 2004).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00049277> <https://orcid.org/0000-0002-1373-1705>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00049277> "2021-02-08T14:06:45Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00049277> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00049277> "FBbt:00049277")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00049277> "larval ring gland")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00049277> <http://purl.obolibrary.org/obo/FBbt_00001722>)
