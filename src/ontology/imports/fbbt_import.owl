AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00110639> "Neuropil mass below the esophagus in the adult brain. It encompasses the gnathal ganglion, the prow and the saddle.")
