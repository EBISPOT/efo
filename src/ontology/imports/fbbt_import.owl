# Class: <http://purl.obolibrary.org/obo/FBbt_00002618> (larval abdominal 9 nerve)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00002618> "Nerve of larval abdominal segment 9 that has features of both the intersegmental and segmental nerves of more anterior segments (Campos-Ortega and Hartenstein, 1997). It has two roots and its proximal section is closely attached to the abdominal 8 nerve (Campos-Ortega and Hartenstein, 1997). After passing beneath the gut suspensor muscles, it gives off a thick recurrent branch, the hindgut nerve, which innervates the hindgut (Campos-Ortega and Hartenstein, 1997). Its main branch continues dorsoposteriorly and gives off a motor branch that innervates the A9 terminal oblique muscles (Campos-Ortega and Hartenstein, 1997). A posterior branch carries sensory axons from the anal sense organ and a dorsal branch carries axons of motor and sensory neurons of A9 (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00002618> "VFB:FBbt_00002618")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00002618> "nerve of a9")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00002618> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00002618> "larval abdominal 9 intersegmental nerve")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00002618> "FBbt:00002618")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00002618> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00002618> "larval abdominal 9 nerve")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00002618> <http://purl.obolibrary.org/obo/FBbt_00047362>)
