# Class: <http://purl.obolibrary.org/obo/FBbt_00007321> (embryonic cardioblast)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0151925") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0219200") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00007321> "Embryonic precursor of a cardial cell, which forms part of the inner, contractile layer of the dorsal vessel. These cells become morphologically distinct during stage 14, when they stretch, flatten and develop dorsally directed processes (Campos-Ortega and Hartenstein, 1997). During dorsal closure, they are squeezed between the amnioserosa and epidermis, and the cardioblasts of either side meet at the dorsal midline once the amnioserosa separates from the epidermis (Campos-Ortega and Hartenstein, 1997). The dorsal vessel is formed when the lateral edges of the cardioblasts curve around ventrally to meet and interdigitate leaving a medial lumen (Campos-Ortega and Hartenstein, 1997). These cells do not finish differentiating into specialized subtypes until after larval hatching (Lehmacher et al., 2012).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00007321> <https://orcid.org/0000-0002-7073-9172>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00007321> "2008-12-03T02:19:59Z"^^xsd:dateTime)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0219200") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00007321> "embryonic cardiomyoblast")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007321> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007321> "FBbt:00007321")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00007321> "embryonic cardioblast")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007321> <http://purl.obolibrary.org/obo/FBbt_00001666>)

