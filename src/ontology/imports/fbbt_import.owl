# Class: <http://purl.obolibrary.org/obo/FBbt_00007054> (superior lateral protocerebrum)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0211016") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "VFB_vol:00045031") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00007054> "Lateral synaptic neuropil domain of the adult superior neuropils. It lies behind the anterior optic tubercle, in front of the mushroom body calyx and above the superior clamp and lateral horn. Its boundary with the anterior optic tubercle (AOTU), mushroom body calyx and lateral horn is demarcated by the extent of arborization of visual projection neurons and antennal lobe projection neurons. Boundaries with the superior clamp, anterior and posterior ventro-lateral protocerebrum are defined using clearly distinguishable fiber bundles.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasAlternativeId> <http://purl.obolibrary.org/obo/FBbt_00007054> "FBbt:00045031")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00007054> "VFB:FBbt_00007054")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00007054> "SLP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00007054> "adult superior lateral protocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007054> "fly_anatomy.ontology")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007054> "DLP")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007054> "IDLP")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007054> "slpr")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007054> "FBbt:00007054")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00007054> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00007054> "Boundaries defined by Ito et al. (2014) (used to define this term) differ slightly from those defined for slpr in Otsuna and Ito, 2006. The anterior superior SLP corresponds to mslpr and the posterior superior SLP to pslpr of Otsuna and Ito (2006). The SLP also corresponds to the lateral part of the dorsolateral protocerebrum (DLP) and lateral part of the inner dorsolateral protocerebrum (IDLP) of Chiang et al. (2011) (Ito et al., 2014).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00007054> "superior lateral protocerebrum")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007054> <http://purl.obolibrary.org/obo/FBbt_00040007>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007054> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00007145>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007054> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00045030>))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007054> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00007064>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00007055> (superior medial protocerebrum)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FBC:AJ") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FBC:VH") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0211016") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "VFB_vol:00007055") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00007055> "Medial synaptic neuropil domain of the adult superior neuropils that lies above the area flanked by the mushroom lobes, pedunculus, and calyx. It is separated from the pedunculus by the superior clamp and insulated from the medial lobe by the crepine. The fan-shaped body protrudes deeply into this neuropil, separating it into anterior (ASMP) and posterior (PSMP) regions.")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym> <http://purl.obolibrary.org/obo/FBbt_00007055> "IDLP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00007055> "VFB:FBbt_00007055")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00007055> "SMP")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasNarrowSynonym> <http://purl.obolibrary.org/obo/FBbt_00007055> "SDFP")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007055> "fly_anatomy.ontology")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212889") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007055> "impr")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007055> "smpr")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007055> "FBbt:00007055")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00007055> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00007055> "Different regions of the SMP correspond to the subdivisions of the smpr and impr (Otsuna and Ito, 2006). The anterior and posterior regions of the superior SMP match part of smpr; the anterior and posterior regions of the inferior SMP match part of impr. The SMP also corresponds to the superior dorsofrontal protocerebrum (SDFP) and to the medial part of the inner dorsolateral protocerebrum (IDLP) of Chiang et al. (2011) (Ito et al., 2014).")
