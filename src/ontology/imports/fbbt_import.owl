AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00007053> "fly_anatomy.ontology")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00007053> "lateral protocerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00007053> "FBbt:00007053")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00007053> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00007053> "adult lateral horn")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007053> <http://purl.obolibrary.org/obo/FBbt_00040007>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00007053> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00007145>))
