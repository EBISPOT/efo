# Class: <http://purl.obolibrary.org/obo/FBbt_00002665> (posterior pharyngeal sense organ)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0045366") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0074007") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0075072") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0167539") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00002665> "Larval sense organ of the intercalary segment that is found on the floor of the larval pharynx (Campos-Ortega and Hartenstein, 1997). Its cuticular elements appear as two small bulges on each side, with minute rods facing the cytoplasm (Jurgens et al., 1986). Each of these two sensilla houses three neurons (Gendre et al., 2004), which follow the hypopharyngeal nerve (Campos-Ortega and Hartenstein, 1997).")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0002274") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00002665> "Organ X")
