AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0007735") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003184> "A discrete, large, ovoid cell attached to the dorsal diaphragm in the abdomen and near the anterior end of the ventriculus in the thorax. Some of these cells are binucleate.")
