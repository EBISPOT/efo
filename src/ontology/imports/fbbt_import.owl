# Class: <http://purl.obolibrary.org/obo/FBbt_00110636> (adult cerebral ganglion)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00110636> "The supraesophageal neuropils of the adult brain located above, around and partially below the esophagus, including the optic lobes. It excludes the gnathal ganglion. Developmentally, it comprises three fused neuromeres: protocerebrum, deutocerebrum, and tritocerebrum.")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00110636> <https://orcid.org/0000-0001-5948-3092>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00110636> "2013-10-08T17:05:57Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00110636> "UBERON:6110636")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00110636> "VFB:FBbt_00110636")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00110636> "CRG")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00110636> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00110636> "SPG")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00110636> "adult supraesophageal ganglion")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00110636> "brain")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00110636> "cerebrum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00110636> "FBbt:00110636")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00110636> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00110636> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00110636> "This term is related to what used to be called supraesophageal ganglion, and is now referred to as supraesophageal zone. The adult cerebral ganglion, together with the gnathal ganglia (GNG), denote regions that follow the segmental neuromeres of the brain (the 3 rostral and 3 caudal, respectively). These are distinguishable from supra- and subesophageal zones, as these refer to the neuropil masses above and below the esophagus and do not respect neuromere boundaries (Ito et al., 2014).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00110636> "adult cerebral ganglion")
EquivalentClasses(<http://purl.obolibrary.org/obo/FBbt_00110636> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/FBbt_00003626> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002131> <http://purl.obolibrary.org/obo/FBbt_00003004>)))
