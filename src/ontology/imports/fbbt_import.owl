# Class: <http://purl.obolibrary.org/obo/FBbt_00049950> (larval fat cell)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0191901") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193562") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0238315") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00049950> "Fat cell that, during larval development, is flat, polygonal and tightly associated with other fat cells in the larval fat body (Nelliot et al., 2006). They accumulate nutrient reserves to act as a reservoir to support the animal through the non-feeding period of development (Aguila et al., 2007). Unlike the adult fat cells, they are endoreplicative (Musselman and Kuhnlein, 2018). After pupation, the larval fat cells adopt a more rounded shape and detach from each other in an anterior to posterior wave, leaving free-floating larval fat cells (Nelliot et al., 2006). The dissociated larval fat cells persist into the newly-eclosed adult to provide a food source (Aguila et al., 2007).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00049950> <https://orcid.org/0000-0002-1373-1705>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00049950> "2020-12-08T11:09:08Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00049950> "larval adipose cell")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00049950> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00049950> "FBbt:00049950")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00049950> "larval fat cell")
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00049950> <http://purl.obolibrary.org/obo/FBbt_00046052>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00049950> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002202> <http://purl.obolibrary.org/obo/FBbt_00049953>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00049952> (larval fat cell of larval fat body)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0049074") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0191901") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193562") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00049952> "Fat cell of the late embryo, larva or early pupa that is part of the mature larval fat body. These cells are flat, polygonal and tightly associated with one another in single-layer sheets (Nelliot et al., 2006). They accumulate nutrient reserves to act as a reservoir to support the animal through the non-feeding period of development (Aguila et al., 2007). There are approximately 2200 of these cells (Butterworth et al., 1988).")
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/FBbt_00049952> <https://orcid.org/0000-0002-1373-1705>)
AnnotationAssertion(<http://purl.org/dc/terms/date> <http://purl.obolibrary.org/obo/FBbt_00049952> "2020-12-08T12:28:26Z"^^xsd:dateTime)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00049952> "embryonic/larval fat cell of fat body")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00049952> "larval adipose cell of larval fat body")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00049952> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00049952> "FBbt:00049952")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00049952> "larval fat cell of larval fat body")
EquivalentClasses(<http://purl.obolibrary.org/obo/FBbt_00049952> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/FBbt_00046052> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002131> <http://purl.obolibrary.org/obo/FBbt_00001727>)))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00049952> <http://purl.obolibrary.org/obo/FBbt_00049950>)
