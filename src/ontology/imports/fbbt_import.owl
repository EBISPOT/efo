# Class: <http://purl.obolibrary.org/obo/FBbt_00005519> (trunk visceral muscle primordium)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0089570") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0190261") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00005519> "Primordium that is derived from the trunk mesoderm and produces larval visceral musculature (Campos-Ortega and Hartenstein, 1997). This produces all of the visceral muscle except for that of the esophagus (Campos-Ortega and Hartenstein, 1997; de Velasco et al., 2006).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00005519> "fly_anatomy.ontology")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00005519> "ViMusP2")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00005519> "FBbt:00005519")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00005519> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00005519> "trunk visceral muscle primordium")
