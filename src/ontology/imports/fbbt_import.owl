AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00001726> "corpora cardiacum")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00001726> "FBbt:00001726")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00001726> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00001726> "embryonic/larval corpus cardiacum")
