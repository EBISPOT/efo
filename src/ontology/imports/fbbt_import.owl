# Class: <http://purl.obolibrary.org/obo/FBbt_00014013> (adult gnathal ganglion)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00014013> "Ventral region of the adult brain, consisting of the fused ganglia of the three gnathal neuromeres; mandibular, maxillary and labial (Ito et al., 2014). It is found beneath the esophagus in the ventral part of the subesophageal zone (Ito et al., 2014).")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/FBbt_00014013> "VFB:FBbt_00014013")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasSynonymType> <http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV>) <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "GNG")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasOBONamespace> <http://purl.obolibrary.org/obo/FBbt_00014013> "fly_anatomy.ontology")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0224194") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "SEG")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0212704") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "SOG")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "adult subesophageal ganglion")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0193607") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "ipsl")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0080339") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/FBbt_00014013> "suboesophageal ganglion")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/FBbt_00014013> "FBbt:00014013")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00014013> <http://purl.obolibrary.org/obo/fbbt#BrainName>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#inSubset> <http://purl.obolibrary.org/obo/FBbt_00014013> <http://purl.obolibrary.org/obo/fbbt#cur>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/FBbt_00014013> "This term refers to what used to be called subesophageal ganglion (SOG). The new name, together with cerebral ganglia (CRG), denote the segmental neuromeres of the brain (the 3 caudal and 3 rostral, respectively). These are distinguishable from supra- and subesophageal zones, as these refer to the neuropil masses above and below the esophagus and do not respect neuromere boundaries (Ito et al., 2014). The posterior part of the GNG also corresponds to part of the inferior ipsl of Otsuna and Ito (2006) and to the ventral part of the subesophageal ganglion (SOG) of Chiang et al. (2011) (Ito et al., 2014).")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00014013> "adult gnathal ganglion")
EquivalentClasses(<http://purl.obolibrary.org/obo/FBbt_00014013> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/FBbt_00004013> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002131> <http://purl.obolibrary.org/obo/FBbt_00003004>)))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00014013> <http://purl.obolibrary.org/obo/FBbt_00004013>)
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00014013> ObjectIntersectionOf(ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00047887>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00110639>)))
SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00014013> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00110639>))
