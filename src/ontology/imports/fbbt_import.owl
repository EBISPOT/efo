SubClassOf(<http://purl.obolibrary.org/obo/FBbt_00003040> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0002150> <http://purl.obolibrary.org/obo/FBbt_00003074>))

# Class: <http://purl.obolibrary.org/obo/FBbt_00003041> (adult tracheal transverse connective)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0011558") Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FlyBase:FBrf0186027") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/FBbt_00003041> "Transverse tracheal branch of the adult. It connects the lateral trunk and the dorsal trunk at seven different locations. At the level of the second pair of spiracles, these connectives are much shorter and stouter than the six abdominal connectives.")
