AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FBbt_00110174> "adult prothoracic neuromere")
EquivalentClasses(<http://purl.obolibrary.org/obo/FBbt_00110174> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/FBbt_00052718> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000050> <http://purl.obolibrary.org/obo/FBbt_00000017>)))
