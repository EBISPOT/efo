# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0003> (obsolete country)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0003> "A collective generic term that refers here to a wide variety of dependencies, areas of special sovereignty, uninhabited islands, and other entities in addition to the traditional countries or independent states.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0100001> <http://purl.obolibrary.org/obo/HANCESTRO_0003> "http://purl.obolibrary.org/obo/NCIT_C25464")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0003> "obsolete country")
AnnotationAssertion(owl:deprecated <http://purl.obolibrary.org/obo/HANCESTRO_0003> "true"^^xsd:boolean)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0004> (ancestry category)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0004> "Population category defined using ancestry informative markers (AIMs) based on genetic/genomic data")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0004> "ancestral group")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0004> "ancestry category")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0004> <http://purl.obolibrary.org/obo/OBI_0000181>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0005> (European ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0005> "Includes individuals who either self-report or have been described by authors as
European, Caucasian, White or one of the sub-populations from this region (e.g Dutch). This category also includes individuals who genetically cluster with reference populations from this region, for example 1000 Genomes and/or HapMap CEU, FIN, GBR, IBS and TSI populations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0005> "Caucasian")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0005> "European")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0005> "white")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/HANCESTRO_0005> "It should be noted that the synonym \"Caucasian\", while widely used in some part of the world, has strong associations with notions of white supremancy and should be avoided whenever possible.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0005> "European ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0005> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0006> (South Asian ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0006> "Includes individuals who either self-report or have been described by authors as South Asian or one of the sub-populations from this region (e.g Asian Indian). This category also includes individuals who genetically cluster with reference populations from this region, for example 1000 Genomes and/or HapMap
BEB, GIH, ITU, PJL and STU populations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0006> "South Asian")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0006> "South Asian ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0006> <http://purl.obolibrary.org/obo/HANCESTRO_0008>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0007> (South East Asian ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0007> "Includes individuals who either self-report or have been described by authors as South East Asian or one of the sub-populations from this region (e.g Vietnamese). This category also includes includes individuals who genetically cluster with reference populations from this region, for example 1000 Genomes KHV population. We note that East Asian and South East Asian populations are often conflated. However, recent studies indicate a unique genetic background for South East Asian populations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0007> "South East Asian")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0007> "Southeast Asian")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0007> "South East Asian ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0007> <http://purl.obolibrary.org/obo/HANCESTRO_0008>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0008> (Asian ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0008> "Includes individuals that either self-report or have been described as Asian but there was not sufficient information to allow classification as East Asian, Central Asian, South Asian or South-East Asian."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0008> "Asian")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0008> "Asian unspecified")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0008> "Asian ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0008> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0009> (East Asian ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0009> "Includes individuals who either self-report or have been described by authors as East Asian or one of the sub-populations from this region (e.g Chinese). This category also includes individuals who genetically cluster with reference populations from this region, for example 1000 Genomes and/or HapMap CDX, CHB, CHS and JPT populations."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0009> "East Asian")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0009> "East Asian ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0009> <http://purl.obolibrary.org/obo/HANCESTRO_0008>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0010> (African ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0010> "Includes individuals that either self-report or have been described as African, but there was not sufficient information to allow classification as African American, AfroCaribbean or Sub-Saharan African."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0010> "African")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0010> "African unspecified"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0010> "African ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0010> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0013> (Indigenous American ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0013> "Includes indigenous individuals of North, Central and South America, descended from the original human migration into the Americas from Siberia. We note that there does not appear to be a suitable reference population for this category and efforts are required to fill this gap."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0013> "Indigenous American")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/HANCESTRO_0013> "Class previously labelled as \"Native American\". Use of this term, alongside other terms such as \"First Nations\", should be discontinued in favour of the more appropriate \"Indigenous American\", which includes indigenous communities across the Americas while the former serve as political designations in the USA and Canada, respectively.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0013> "Indigenous American ancestry"@en)
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0013> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0014> (Latin or Admixed American ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Includes individuals who either self-report or are described by authors as Hispanic, Latino, Latin American or one of the sub-populations from this region. This category includes individuals with known admixture of primarily European, African and Native American ancestries, though some may have also a degree of Asian (e.g. Peru). We also note that the levels of admixture vary depending on the country, with Caribbean countries carrying higher levels of African admixture when compared to South American countries, for example. This category also includes individuals who genetically cluster with reference populations from this region, for example 1000 Genomes and/or HapMap CLM, MXL, PEL and PUR populations")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Jackie MacArthur")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Joannella Morales")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Latin or Admixed American")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Mestizo")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Pardo")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Synonyms include historical and contemporary terms in use in parts of Canada, Alaska and USA by some Indigenous populations, local and national governmental institutions")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0014> "Latin or Admixed American ancestry")
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0014> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0014> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/HANCESTRO_0301> <http://purl.obolibrary.org/obo/HANCESTRO_0306>))

# Class: <http://purl.obolibrary.org/obo/HANCESTRO_0015> (Greater Middle Eastern (Middle Eastern or North African or Persian) ancestry)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/HANCESTRO_0015> "Includes individuals who self-report or were described by authors as Middle Eastern, North African, Persian or one of the subpopulations from this region (e.g. Saudi Arabian). We note there is heterogeneity in this category with different degrees of admixture as well as levels of genetic isolation. We note that there does not appear to be a suitable reference population for this category and efforts are required to fill this gap."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0015> "Greater Middle Eastern (Middle Eastern or North African or Persian)")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/HANCESTRO_0015> "Middle Eastern/North African")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/HANCESTRO_0015> "Greater Middle Eastern (Middle Eastern or North African or Persian) ancestry"@en)
SubClassOf(<http://purl.obolibrary.org/obo/HANCESTRO_0015> <http://purl.obolibrary.org/obo/HANCESTRO_0004>)

