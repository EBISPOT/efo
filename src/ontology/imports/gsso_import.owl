# Class: <http://purl.obolibrary.org/obo/GSSO_000701> (monosexuality)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GSSO_000701> "A sexuality that involves attraction to only one sex: generally, homosexuality or heterosexuality."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000701> "https://en.wiktionary.org/wiki/monosexuality#English"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000701> "https://www.wikidata.org/wiki/Q1632385"^^xsd:anyURI)
