AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://lgbt.dk/ordbog/seksualitet/"^^xsd:anyURI) rdfs:label <http://purl.obolibrary.org/obo/GSSO_000414> "seksualitet"@da)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GSSO_000414> "sexuality"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GSSO_000414> <http://purl.obolibrary.org/obo/GSSO_000413>)

# Class: <http://purl.obolibrary.org/obo/GSSO_000699> (asexuality)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GSSO_000699> "Asexuality is the lack of sexual attraction to others, or low or absent interest in or desire for sexual activity."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000699> "https://bisexuality.wikia.org/wiki/Asexuality"^^xsd:anyURI)
