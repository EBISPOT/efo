AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://lgbtqia.fandom.com/wiki/Monosexual"^^xsd:anyURI) <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/GSSO_000701> "monosexual"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GSSO_000701> "monosexuality"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GSSO_000701> <http://purl.obolibrary.org/obo/GSSO_000700>)

# Class: <http://purl.obolibrary.org/obo/GSSO_000702> (plurisexuality)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GSSO_000702> "The state of being sexually and romantically attracted to members of more than one gender."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000702> "https://en.wiktionary.org/wiki/plurisexuality#English"^^xsd:anyURI)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GSSO_000702> "plurisexuality"@en)
SubClassOf(<http://purl.obolibrary.org/obo/GSSO_000702> <http://purl.obolibrary.org/obo/GSSO_000700>)
SubClassOf(<http://purl.obolibrary.org/obo/GSSO_000702> <http://purl.obolibrary.org/obo/GSSO_001379>)

# Class: <http://purl.obolibrary.org/obo/GSSO_000703> (bisexuality)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GSSO_000703> "The state of being sexually attracted to members of female and male sexes (in non-human animals). In humans, bisexuality has historically been used to mean attraction to men and women, but is usually used today to refer to persons who are sexually and/or romantically attracted to persons with a gender or genders like theirs and those with a gender or genders unlike theirs."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://en.wikipedia.org/wiki/Bisexuality"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://en.wikipedia.org/wiki/Category:Bisexuality"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://lgbt-plus.fandom.com/wiki/Bisexuality"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://lgbt.wikia.org/wiki/Bisexuality"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://rainbowpedia.wikia.org/wiki/Bisexuality"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000703> "https://www.wikidata.org/wiki/Q43200"^^xsd:anyURI)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/GSSO_000703> "bi-sexualism"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/GSSO_000703> "bisexualism"@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/GSSO_000703> "Historically, bi-sexuality or bisexuality (or being bi-sexual or bisexual) referred to having qualities of both the male and female sexes, i.e. being intersex or, in some cases, transgender."@en)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://en.wiktionary.org/wiki/biseksualitet#Albanian"^^xsd:anyURI) rdfs:label <http://purl.obolibrary.org/obo/GSSO_000703> "biseksualitet"@sq)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GSSO_000703> "bisexuality"@en)
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "https://en.wiktionary.org/wiki/%D0%B1%D0%B8%D1%81%D0%B5%D0%BA%D1%81%D1%83%D0%B0%D0%BB%D0%BD%D0%BE%D1%81%D1%82#Bulgarian"^^xsd:anyURI) rdfs:label <http://purl.obolibrary.org/obo/GSSO_000703> "бисексуа́лност"@bg)
SubClassOf(<http://purl.obolibrary.org/obo/GSSO_000703> <http://purl.obolibrary.org/obo/GSSO_000710>)

# Class: <http://purl.obolibrary.org/obo/GSSO_000704> (пансексуа́лност)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GSSO_000704> "A sexual orientation characterized by the potential for aesthetic attraction, romantic love and/or sexual desire for people, regardless of their gender identity or biological sex."@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GSSO_000704> "https://en.wikipedia.org/wiki/Pansexuality"^^xsd:anyURI)
