                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007129"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Group of synaptic neuropil domains in the adult brain located between the antennal lobe/ventromedial neuropils and above the gnathal ganglia. In addition, it includes one synaptic domain that is part of the ventral cerebral ganglion-the prow.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00045047</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>PENP</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00045047</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <rdfs:comment>Despite the name, it is intended as a singular noun as in &quot;The United States&quot;.</rdfs:comment>
        <rdfs:label>adult periesophageal neuropils</rdfs:label>
    </owl:Class>
    <owl:Axiom>
