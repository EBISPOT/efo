        <oboInOwl:hasExactSynonym>protocerebral neuromere</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00003627</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Urbach and Technau (2003) divide the protocerebrum into labral and ocular neuromeres.</rdfs:comment>
        <rdfs:label>protocerebrum</rdfs:label>
    </owl:Class>
    <owl:Axiom>
