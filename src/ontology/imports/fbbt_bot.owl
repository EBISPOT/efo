            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>One of the two cyst cells that make up a 2-cell female germline cyst, resulting from the first division of a cystoblast (Hinnant et al., 2020).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-6095-8718"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-08-30T16:22:58Z</terms:date>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00059157</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>cyst cell of female germline 2-cell cyst</rdfs:label>
