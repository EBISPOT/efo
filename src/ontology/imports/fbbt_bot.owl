    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005607">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005752"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000438"/>
            </owl:Restriction>
        </rdfs:subClassOf>
