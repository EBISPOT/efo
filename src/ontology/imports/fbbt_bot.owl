        <obo:IAO_0000115>Primary neuron belonging to a hemilineage that has active Notch signaling. In the larval ventral nerve cord, Notch ON neurons tend to project to the dorsal (motor) neuropil and have distinct morphologies from their Notch OFF counterparts in the same lineage (Mark et al., 2021).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-02-25T12:55:40Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00047106</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>A hemilineage primary neuron</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047106</oboInOwl:id>
        <rdfs:label>Notch ON hemilineage primary neuron</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047106"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Primary neuron belonging to a hemilineage that has active Notch signaling. In the larval ventral nerve cord, Notch ON neurons tend to project to the dorsal (motor) neuropil and have distinct morphologies from their Notch OFF counterparts in the same lineage (Mark et al., 2021).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0249021</oboInOwl:hasDbXref>
    </owl:Axiom>
    


