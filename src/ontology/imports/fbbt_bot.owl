        <oboInOwl:id>FBbt:00005566</oboInOwl:id>
        <rdfs:comment>Obsoleted as definition makes this equivalent to &apos;larval midline neuron&apos; FBbt:00016016 - https://orcid.org/0000-0002-1373-1705.</rdfs:comment>
        <rdfs:label>obsolete ventral midline neuron</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
