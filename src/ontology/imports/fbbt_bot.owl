        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Developing labial sensory organ that has not yet reached its mature larval state. It starts to become distinct, and the developing neurons form nerves, during stage 13 (Campos-Ortega and Hartenstein, 1997). As foregut structures move inwards, it becomes incorporated into the ventral part of atrium around stage 15 (Campos-Ortega and Hartenstein, 1997).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
    </owl:Axiom>
    


