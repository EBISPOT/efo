    <!-- http://purl.obolibrary.org/obo/GO_0007603 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0007603">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007602"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0009584"/>
        <obo:IAO_0000115>The sequence of reactions within a cell required to convert absorbed photons from visible light into a molecular signal. A visible light stimulus is electromagnetic radiation that can be perceived visually by an organism; for organisms lacking a visual system, this can be defined as light with a wavelength within the range 380 to 780 nm.</obo:IAO_0000115>
