                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004924"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Epithelial tube that connects the lateral oviducts to the uterus (Heifetz et al., 2000; Adams and Wolfner, 2007; Kapelnikov et al., 2008; Heifetz et al., 2014; McQueen et al., 2022). It is lined with a chitinous intima, and surrounded by circular muscles (McQueen et al., 2022).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>main oviduct</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
