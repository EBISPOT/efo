    <!-- http://purl.obolibrary.org/obo/FBbt_00005668 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005668">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005803"/>
