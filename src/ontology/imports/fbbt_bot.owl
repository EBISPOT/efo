            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Female germline cell that develops from one of the 16 cyst cells (the presumptive oocyte) produced by a cystoblast. It matures in an egg chamber of the ovariole and will be released from the ovary as an egg.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>CL:0000023</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
