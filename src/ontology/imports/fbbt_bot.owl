        <oboInOwl:hasDbXref>Reactome:R-HSA-9620244</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Wikipedia:Neurotransmission</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>neurotransmission</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>GO:0007268</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/go#goslim_synapse"/>
        <rdfs:label>chemical synaptic transmission</rdfs:label>
    </owl:Class>
