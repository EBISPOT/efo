    <!-- http://purl.obolibrary.org/obo/FBbt_00000129 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00000129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004208"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005495"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000128"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Outer layer of the trunk mesoderm that arises due to mitosis at the end of stage 10 (Campos-Ortega and Hartenstein, 1997). It will give rise to the segmentally-repeated body wall muscles and the fat body (Campos-Ortega and Hartenstein, 1997).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>somatopleura</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00000129</oboInOwl:id>
