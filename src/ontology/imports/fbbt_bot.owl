            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Neuropil mass below the esophagus in the adult brain. It encompasses the gnathal ganglion, the prow and the saddle.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-5948-3092"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2013-10-08T17:53:57Z</terms:date>
