            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The endocrine complex which consists of the corpus cardiacum and corpus allatum (Hartenstein, 2006; Lee et al., 2008).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:0012325</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>CC-CA</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>retrocerebral neuroendocrine complex</oboInOwl:hasExactSynonym>
