    <!-- http://purl.obolibrary.org/obo/FBbt_00045039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00045039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040007"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040037"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Thin, elongated, antler-shaped, bilaterally paired synaptic neuropil domain spanning from the inferior bridge to the inferior edge of the superior lateral protocerebrum. It runs through the space between the protocerebral bridge and the fan-shaped body, along the medial surface of the medial antennal lobe tract.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>CCP</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>IPp</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>pimpr</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>posterior inferior protocerebrum</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>VFB:FBbt_00045039</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>ATL</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00045039</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <rdfs:comment>The antler corresponds to part of the medial part of the pimpr of Otsuna and Ito (2006) and to the dorsal part of the caudalcentral protocerebrum (CCP) of Chiang et al. (2011) and to part of the posterior inferior protocerebrum (Ito et al., 2014).</rdfs:comment>
        <rdfs:label>antler</rdfs:label>
    </owl:Class>
    <owl:Axiom>
