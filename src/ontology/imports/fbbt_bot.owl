    <!-- http://purl.obolibrary.org/obo/FBbt_00047166 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00047166">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007474"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047143"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tubular epithelium composed of a monolayer of cells. Different regions have different developmental origins. Both the foregut and hindgut originate from the ectoderm, whereas the midgut originates from the endoderm. A layer of cuticle lines the foregut and hindgut. In the midgut, a semipermeable chitinous layer, the peritrophic matrix, protects the epithelium from physical damage and regulates the passage of particles between the lumen and enterocytes.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <oboInOwl:hasDbXref>UBERON:0003929</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047166</oboInOwl:id>
        <rdfs:label>gut epithelium</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047166"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A tubular epithelium composed of a monolayer of cells. Different regions have different developmental origins. Both the foregut and hindgut originate from the ectoderm, whereas the midgut originates from the endoderm. A layer of cuticle lines the foregut and hindgut. In the midgut, a semipermeable chitinous layer, the peritrophic matrix, protects the epithelium from physical damage and regulates the passage of particles between the lumen and enterocytes.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0222424</oboInOwl:hasDbXref>
    </owl:Axiom>
    


