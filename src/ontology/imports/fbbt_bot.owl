                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004924"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
