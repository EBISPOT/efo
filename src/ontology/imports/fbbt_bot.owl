    <!-- http://purl.obolibrary.org/obo/FBbt_00001105 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001105">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005103"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001919"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Most anterior of the two main commissures found in each neuromere (the only commissure in A9) of the larval ventral nerve cord (Landgraf et al., 2003; Birkholz et al., 2015). In some segments, at some stages these can be further divided into multiple components along the dorsal-ventral axis (Truman et al., 2004; Birkholz et al., 2015; Hartenstein et al., 2018).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00001105</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>aC</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>embryonic/larval anterior commissure</oboInOwl:hasExactSynonym>
