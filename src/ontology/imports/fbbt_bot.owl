        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001850"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Paired dorsal process of the pharyngeal sclerite. This structure, into which the cibarial muscle inserts, is situated in the narrow lumen of the dorsal pouch. It is connected anteriorly to the dorsal bridge (also known as latticed process) and ventrally to the vertical bridge (also known as vertical plate).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://www.wikidata.org/entity/Q3074571"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2008-05-12T11:37:59Z</terms:date>
        <oboInOwl:hasExactSynonym>dorsal cornua</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>dorsal posterior process</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>dorsal wing</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00007164</oboInOwl:id>
        <rdfs:comment>This term replaces the much misused term &apos;dorsal wing&apos; (FBbt:00001853).</rdfs:comment>
        <rdfs:label>dorsal arm of pharyngeal sclerite</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007164"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Paired dorsal process of the pharyngeal sclerite. This structure, into which the cibarial muscle inserts, is situated in the narrow lumen of the dorsal pouch. It is connected anteriorly to the dorsal bridge (also known as latticed process) and ventrally to the vertical bridge (also known as vertical plate).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBim0000950</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0045366</oboInOwl:hasDbXref>
    </owl:Axiom>
