        <oboInOwl:hasRelatedSynonym>posterior endoderm primordium P2</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>posterior midgut primordium rudiment</oboInOwl:hasRelatedSynonym>
