    <!-- http://purl.obolibrary.org/obo/FBbt_00005048 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005048">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005038"/>
