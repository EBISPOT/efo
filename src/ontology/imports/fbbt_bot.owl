    <!-- http://purl.obolibrary.org/obo/FBbt_00048289 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00048289">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00051405"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001930"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002216"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0050953"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Small neuropil compartment of the larval optic lobe that contains the axons of photoreceptors. It is the first center for visual processing in the larval brain. It is largely surrounded by the outer optic anlage at earlier developmental stages and becomes sandwiched between the developing proximal medulla and the inner optic anlage by third instar. It is incorporated into the adult optic lobe as the accessory medulla.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-04-17T09:14:28Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00048289</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>larvalbrain_neuropil:379</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>larvalbrain_neuropil:557</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>LON</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00048289</oboInOwl:id>
        <rdfs:label>larval optic neuropil</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048289"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Small neuropil compartment of the larval optic lobe that contains the axons of photoreceptors. It is the first center for visual processing in the larval brain. It is largely surrounded by the outer optic anlage at earlier developmental stages and becomes sandwiched between the developing proximal medulla and the inner optic anlage by third instar. It is incorporated into the adult optic lobe as the accessory medulla.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0215208</oboInOwl:hasDbXref>
