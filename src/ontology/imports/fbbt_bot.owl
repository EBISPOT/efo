    <!-- http://purl.obolibrary.org/obo/FBbt_00005801 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005801">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025991"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00041000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003627"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005508"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002216"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0007613"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Bilaterally paired neuropil structure situated postero-dorsally in the protocerebrum that functions in olfactory associative learning and memory. The mushroom body is divided into: the calyx, which is closest to the cortex and receives sensory interneuron afferents; the pedunculus, which is a thick axon bundle extending from the calyx to the base of the lobes; and the mushroom body lobe system, which consists of a vertical branch and a medial branch, which have different structures at different life stages (Lee et al., 1999; Ito et al., 2014).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:0001058</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VFB:FBbt_00005801</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>MB</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>corpora pedunculata</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005801</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#FB_gloss"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>This term as defined in Ito et al. (2014) corresponds to both the mushroom body (MB) and calyx (Cal) of Chiang et al. (2011).</rdfs:comment>
        <rdfs:label>mushroom body</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005801"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Bilaterally paired neuropil structure situated postero-dorsally in the protocerebrum that functions in olfactory associative learning and memory. The mushroom body is divided into: the calyx, which is closest to the cortex and receives sensory interneuron afferents; the pedunculus, which is a thick axon bundle extending from the calyx to the base of the lobes; and the mushroom body lobe system, which consists of a vertical branch and a medial branch, which have different structures at different life stages (Lee et al., 1999; Ito et al., 2014).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0111409</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0224194</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0248215</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
