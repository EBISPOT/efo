        <oboInOwl:hasDbXref>DOI:10.1093/molehr/gan048</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>https://www.ncbi.nlm.nih.gov/books/NBK9906/</oboInOwl:hasDbXref>
    </owl:Axiom>
    


