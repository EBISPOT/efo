    <!-- http://purl.obolibrary.org/obo/FBbt_00052053 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00052053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005495"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001756"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
