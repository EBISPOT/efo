    <!-- http://purl.obolibrary.org/obo/FBbt_00004048 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004048">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005105"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004550"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002134"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003216"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004021"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Nerve arising from the corpus cardiacum (Rajashekhar and Singh, 1994), located along the dorsal surface of the esophagus. After it exits from the esophageal canal it loops ventrally and anastomoses with the pharyngeal nerve to form the recurrent nerve (Rajashekhar and Singh, 1994). It enters the tritocerebrum, ascends dorsally and arborizes near the midline.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00004048</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>recurrent nerve</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00004048</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Kankel et al. (1980) describe this nerve as arising from the posterior region of the stomodeal ganglion.</rdfs:comment>
        <rdfs:label>adult stomodeal nerve</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004048"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Nerve arising from the corpus cardiacum (Rajashekhar and Singh, 1994), located along the dorsal surface of the esophagus. After it exits from the esophageal canal it loops ventrally and anastomoses with the pharyngeal nerve to form the recurrent nerve (Rajashekhar and Singh, 1994). It enters the tritocerebrum, ascends dorsally and arborizes near the midline.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0034076</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0080339</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004048"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
        <owl:annotatedTarget>recurrent nerve</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007735</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00004052 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004052">
