            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Region of the tracheal primordium that develops into the embryonic/larval transverse connective. During stages 11 and 12, the invaginating tracheal pit forms an L shape. The arm of the L heading inwards from the surface forms the spiracular branch primordium, the other arm forms the transverse connective primordium.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>embryonic transverse connective</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>a and b branch</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>outer segmental trachea</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ventral segmental trachea</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00005580</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>tracheal transverse connective primordium</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005580"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Region of the tracheal primordium that develops into the embryonic/larval transverse connective. During stages 11 and 12, the invaginating tracheal pit forms an L shape. The arm of the L heading inwards from the surface forms the spiracular branch primordium, the other arm forms the transverse connective primordium.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064787</oboInOwl:hasDbXref>
    </owl:Axiom>
    


