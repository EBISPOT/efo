    <!-- http://purl.obolibrary.org/obo/FBbt_00005074 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005074">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00100318"/>
