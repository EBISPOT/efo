            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001841"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005513"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Imaginal cell, set aside during embryonic development, that will give rise to the adult hindgut. These cells are found in two rings of the hindgut; immediately posterior to the ureters of the Malpighian tubules, and at the anus. These two rings grow out and eventually unite.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>adult hindgut precursor</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005646</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>embryonic precursor of adult hindgut</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005646"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Imaginal cell, set aside during embryonic development, that will give rise to the adult hindgut. These cells are found in two rings of the hindgut; immediately posterior to the ureters of the Malpighian tubules, and at the anus. These two rings grow out and eventually unite.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064792</oboInOwl:hasDbXref>
    </owl:Axiom>
    


