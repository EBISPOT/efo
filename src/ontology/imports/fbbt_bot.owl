        <oboInOwl:id>FBbt:00001446</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>This includes immature secondary neurons that are found in the larva - https://orcid.org/0000-0002-1373-1705.</rdfs:comment>
        <rdfs:label>larval neuron</rdfs:label>
    </owl:Class>
    <owl:Axiom>
