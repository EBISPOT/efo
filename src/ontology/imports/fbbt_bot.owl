        <obo:IAO_0000115>The sum of all the anlagen and primordia that will develop into a single system.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-7073-9172"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2010-04-29T07:57:11Z</terms:date>
