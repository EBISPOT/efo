                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004788"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Membrane that is found laterally, between the tergites, on the dorsal side, and the sternites on the ventral side of the adult external abdomen. The abdominal spiracles are found on the most anterior region of the pleural membrane.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00004822</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>pleural membrane</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004822"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Membrane that is found laterally, between the tergites, on the dorsal side, and the sternites on the ventral side of the adult external abdomen. The abdominal spiracles are found on the most anterior region of the pleural membrane.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007734</oboInOwl:hasDbXref>
    </owl:Axiom>
    


