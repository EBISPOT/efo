        <oboInOwl:hasRelatedSynonym>P1 AdMus</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00003232</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>embryonic precursor cell of adult muscle</rdfs:label>
    </owl:Class>
    <owl:Axiom>
