                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005024"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Segmental subdivision of the tracheal system. The most anterior tracheal metamere corresponds to the mesothoracic segment, whereas the most posterior corresponds to abdominal segment 8.</obo:IAO_0000115>
