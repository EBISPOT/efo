        <oboInOwl:hasExactSynonym>DTR</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>dorsal tritocerebral domain</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>dorsomedial neuropil of larval tritocerebrum</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00007719</oboInOwl:id>
