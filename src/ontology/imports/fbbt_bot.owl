                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005095"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The pre-oral neuropils of the brain located above and some of it below the esophagus, comprising three fused ganglia (protocerebrum, deutocerebrum, and tritocerebrum) in the head.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:6003626</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VFB:FBbt_00003626</oboInOwl:hasDbXref>
