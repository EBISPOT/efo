        <oboInOwl:hasNarrowSynonym>adult labellar gustatory association center</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>adult labial gustatory center</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>adult pharyngeal gustatory association center</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>PGC</oboInOwl:hasRelatedSynonym>
