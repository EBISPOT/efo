            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005106"/>
        <obo:IAO_0000115>Somatic, contractile cell that makes up a muscle. It is formed by several fusion events between fusion competent myoblasts and one founder cell.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>CL:0000187</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
