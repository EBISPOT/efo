    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005554"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Primordium which is formed by the delamination of neuroblasts from the ventral neurogenic region. The first of five waves of delamination starts towards the end of embryonic stage 8. During stage 11, the mesectoderm loses contact with the outer surface and forms neuronal and glial precursors in the midline of this primordium.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005554"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
        <owl:annotatedTarget>P3 venNeur</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0002-7073-9172</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00005555 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005555">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005495"/>
        <obo:IAO_0000115>Primordium of the genital disc associated with the development of structures of the opposite sex (Epper and Nothiger, 1982). It is largely, but not completely, repressed from developing into adult structures (Epper and Nothiger, 1982; Keisman et al., 2001).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005555</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>repressed genital primordium</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005555"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Primordium of the genital disc associated with the development of structures of the opposite sex (Epper and Nothiger, 1982). It is largely, but not completely, repressed from developing into adult structures (Epper and Nothiger, 1982; Keisman et al., 2001).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0037847</oboInOwl:hasDbXref>
