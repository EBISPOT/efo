                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005510"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Sense organ of the embryonic antennal segment that gives rise to the dorsal organ of the larval head. It is posterior to the embryonic brain by stage 13 and migrates ventrally and anteriorly to establish its final position, dorsal to the terminal organ, by stage 17.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00005568</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>embryonic dorsal organ</oboInOwl:hasExactSynonym>
