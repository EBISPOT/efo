    <!-- http://purl.obolibrary.org/obo/FBbt_00001939 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001939">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005426"/>
