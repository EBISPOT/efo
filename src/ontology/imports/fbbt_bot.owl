        <oboInOwl:hasDbXref>GOC:jl</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ISBN:0395448956</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>PMID:20160973</oboInOwl:hasDbXref>
