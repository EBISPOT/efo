    <!-- http://purl.obolibrary.org/obo/FBbt_00000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00000034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007001"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004886"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Structure that develops from an oocyte once it has been released from the ovary by ovulation (Qazi et al., 2003). Ovulation triggers egg activation, which alters envelope permeability and causes the resumption of meiosis and translation (Qazi et al., 2003). Fertilization of the egg begins embryogenesis (Loppin et al., 2015).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>ovum</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00000034</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#expressionslim_flybase_ribbon"/>
        <rdfs:label>egg</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000034"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Structure that develops from an oocyte once it has been released from the ovary by ovulation (Qazi et al., 2003). Ovulation triggers egg activation, which alters envelope permeability and causes the resumption of meiosis and translation (Qazi et al., 2003). Fertilization of the egg begins embryogenesis (Loppin et al., 2015).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0158848</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0229233</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000034"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
