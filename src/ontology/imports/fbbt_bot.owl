        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
        <owl:annotatedTarget>cystocyte</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064777</oboInOwl:hasDbXref>
    </owl:Axiom>
