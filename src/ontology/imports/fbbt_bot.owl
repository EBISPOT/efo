            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Embryo during stages 9-12.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>FBdv:00005321</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
