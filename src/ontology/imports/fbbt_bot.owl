            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Tissue which becomes morphologically distinct shortly after cephalic furrow formation as two strips of about 80 enlarged cells which extend dorso-ventrally on either side of the developing head. It gives rise to neuroblasts of the brain.</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>pregnathal neuroectoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>procephalic neuroectoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001058</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>procephalic neurogenic region</rdfs:label>
    </owl:Class>
    <owl:Axiom>
