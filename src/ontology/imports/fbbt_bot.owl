    <!-- http://purl.obolibrary.org/obo/FBbt_00004047 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004047">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005804"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003623"/>
