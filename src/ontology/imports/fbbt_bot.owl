    <!-- http://purl.obolibrary.org/obo/FBbt_00047120 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00047120">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005103"/>
