    <!-- http://purl.obolibrary.org/obo/FBbt_00005643 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005643">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005642"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005795"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025992"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005502"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Tip cell of the embryonic Malpighian tubule. It persists throughout tubule elongation during stages 13-16 and contacts a specific target by the end of the process (Weavers and Skaer, 2013). It adopts a specialized morphology with the cell body projecting from the tubule tip on the end of a microtubule-enriched stalk (Weavers and Skaer, 2013). It can extend filopodia and lamellipodia to explore its environment and remains free of basement membrane (Weavers and Skaer, 2013).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005643</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>embryonic Malpighian tubule tip cell</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005643"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Tip cell of the embryonic Malpighian tubule. It persists throughout tubule elongation during stages 13-16 and contacts a specific target by the end of the process (Weavers and Skaer, 2013). It adopts a specialized morphology with the cell body projecting from the tubule tip on the end of a microtubule-enriched stalk (Weavers and Skaer, 2013). It can extend filopodia and lamellipodia to explore its environment and remains free of basement membrane (Weavers and Skaer, 2013).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0223292</oboInOwl:hasDbXref>
    </owl:Axiom>
    


