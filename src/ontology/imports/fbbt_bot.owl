        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Applies to neuroblasts at all stages of development.</rdfs:comment>
        <rdfs:label>neuroblast of ventral nervous system</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001369"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Neuroblast that generates cells of the ventral nervous system, including interneurons, motor neurons and/or glial cells (Bossing et al., 1996). These neuroblasts derive from the ventral neurectoderm (Bossing et al., 1996).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0090460</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0098344</oboInOwl:hasDbXref>
