        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>In the embryo, individual neuroblasts are named according to their position relative to major morphological features (cephalic furrow, invaginating foregut, dorsal and ventral midline, their relative position with respect to each other, their time of segregation and their expression of markers) (Urbach et al., 2003).</rdfs:comment>
        <rdfs:label>protocerebral neuroblast</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001334"/>
