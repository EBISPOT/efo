    <!-- http://purl.obolibrary.org/obo/FBbt_00004912 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004912">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007474"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048491"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004911"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004865"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004913"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Epithelial tube that connects the ovary to the common oviduct (McQueen et al., 2022). It is lined with a chitinous intima, and surrounded by muscle (McQueen et al., 2022). There are two of these per organism (one per ovary) (McQueen et al., 2022). They usually have a loop near the base of the ovary in unmated females; the loop relaxes after mating to allow egg transit (Kapelnikov et al., 2008; McQueen et al., 2022).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00004912</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>lateral oviduct</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004912"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Epithelial tube that connects the ovary to the common oviduct (McQueen et al., 2022). It is lined with a chitinous intima, and surrounded by muscle (McQueen et al., 2022). There are two of these per organism (one per ovary) (McQueen et al., 2022). They usually have a loop near the base of the ovary in unmated females; the loop relaxes after mating to allow egg transit (Kapelnikov et al., 2008; McQueen et al., 2022).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007735</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0207006</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0253444</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00004913 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004913">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007474"/>
