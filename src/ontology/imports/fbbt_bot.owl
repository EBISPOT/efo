    <!-- http://purl.obolibrary.org/obo/FBbt_00001673 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001673">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/FBbt_00058291"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001727"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00058291"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001664"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A contractile tube in the embryo/larva that extends from immediately behind the posterior commissure of T1 to the arthrodial membrane of A7, into which it inserts via two caudally directed muscles which connect to lateral apodemes in A8. Throughout its length, its lumen is enclosed by just two cardial cells. This single-cell thick layer of cardial cells is surrounded by a single-cell thick layer of pericardial cells, except in the posterior thorax. In this region, it is surrounded by lymph gland in the anterior thorax where it passes through the ring gland. The whole tube is attached to the anterior region of each abdominal segment boundary by alary muscles.</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>FBbt:00005681</oboInOwl:hasAlternativeId>
        <oboInOwl:hasExactSynonym>larval dorsal vessel</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001673</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>embryonic/larval dorsal vessel</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001673"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A contractile tube in the embryo/larva that extends from immediately behind the posterior commissure of T1 to the arthrodial membrane of A7, into which it inserts via two caudally directed muscles which connect to lateral apodemes in A8. Throughout its length, its lumen is enclosed by just two cardial cells. This single-cell thick layer of cardial cells is surrounded by a single-cell thick layer of pericardial cells, except in the posterior thorax. In this region, it is surrounded by lymph gland in the anterior thorax where it passes through the ring gland. The whole tube is attached to the anterior region of each abdominal segment boundary by alary muscles.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00001674 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001674">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00100313"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001673"/>
