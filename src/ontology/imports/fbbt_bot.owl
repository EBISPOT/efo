        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00045032"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasBroadSynonym"/>
        <owl:annotatedTarget>LPC</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0229653</oboInOwl:hasDbXref>
    </owl:Axiom>
