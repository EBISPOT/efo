    <!-- http://purl.obolibrary.org/obo/FBbt_00053396 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00053396">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005125"/>
        <obo:IAO_0000115>An interneuron that has distinct dendritic and axonal branches that arborize in different neuropil regions. These neurons relay information between different parts of the central nervous system.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-21T10:32:23Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00053396</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00053396</oboInOwl:id>
        <rdfs:comment>Includes neurons with axonal and dendritic arbors in the same region if there is another branch that extends elsewhere (Frechter et al., 2019). Excludes neurons that only have a &apos;local&apos; innervation pattern, where both inputs/outputs may be present on arbors that span neuropil boundaries.</rdfs:comment>
        <rdfs:label>input/output neuron</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00053396"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>An interneuron that has distinct dendritic and axonal branches that arborize in different neuropil regions. These neurons relay information between different parts of the central nervous system.</owl:annotatedTarget>
