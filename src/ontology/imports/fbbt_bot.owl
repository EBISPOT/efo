    <!-- http://purl.obolibrary.org/obo/FBbt_00052057 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00052057">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004475"/>
