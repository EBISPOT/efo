                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000053"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/PATO_0002451"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Anterior region of the genital disc that derives from abdominal segment 9 (Keisman et al., 2001). By third instar stage, it constitutes the majority of the disc in the male, but a much smaller proportion in the female (Keisman et al., 2001). In males, it produces the majority of adult male genital structures, in the female it produces the parovaria (Keisman et al., 2001).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-01-17T11:34:59Z</terms:date>
