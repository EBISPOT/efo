    <!-- http://purl.obolibrary.org/obo/FBbt_00007064 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00007064">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040007"/>
