    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00100741">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001333"/>
        <obo:IAO_0000115>Basoanterior neuroblast (Pereanu and Hartenstein, 2006). In the larva, these neuroblasts are located around the antennal compartment (Pereanu et al., 2006). Some of these form the ventral deutocerebrum and two are tritocerebral (Pereanu and Hartenstein, 2006; Kuert et al., 2012).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://www.researchgate.net/scientific-contributions/Simon-Reeve-2162827703"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2011-07-13T02:01:33Z</terms:date>
