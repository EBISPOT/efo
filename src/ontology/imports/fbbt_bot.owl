    <!-- http://purl.obolibrary.org/obo/FBbt_00004924 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004924">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048491"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00100313"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004925"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
