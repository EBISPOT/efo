                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003627"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A neuroblast located in the protocerebrum. None of these are serial homologues of neuroblasts found in the thoracic neuromeres (Urbach et al., 2016).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00001334</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
