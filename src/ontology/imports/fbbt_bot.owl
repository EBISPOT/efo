                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003004"/>
                    </owl:Restriction>
                </owl:intersectionOf>
