        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00052058</oboInOwl:id>
        <rdfs:label>epigynial ventral lobe</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00052058"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Ventral portion of the epigynium below the epigynial dorsal lobe (McQueen et al., 2022). There are two of these per organism, one on each side (McQueen et al., 2022). Each lobe (left and right) normally harbors four or five small, unpigmented sensilla (bristles) (McQueen et al., 2022).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0253444</oboInOwl:hasDbXref>
