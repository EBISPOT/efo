    <!-- http://purl.obolibrary.org/obo/FBbt_00005556 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005556">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005835"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007046"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005331"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000095"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Amnioserosa following dorsal closure (Reed et al., 2004). It initially invaginates to form a tube with its perimeter cells aligning on the dorsal side of the tube, beneath the dorsal midline of the embryo (Reed et al., 2004). Individual cells dissociate from the tube and are engulfed by hemocytes, dying by anoikis (Reed et al., 2004).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005556</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>apoptotic amnioserosa</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005556"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Amnioserosa following dorsal closure (Reed et al., 2004). It initially invaginates to form a tube with its perimeter cells aligning on the dorsal side of the tube, beneath the dorsal midline of the embryo (Reed et al., 2004). Individual cells dissociate from the tube and are engulfed by hemocytes, dying by anoikis (Reed et al., 2004).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0174479</oboInOwl:hasDbXref>
    </owl:Axiom>
    


