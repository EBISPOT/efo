        <oboInOwl:hasRelatedSynonym>antEndoP2</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>antMGRudP2</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>anterior endoderm primordium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>anterior midgut rudiment</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00005559</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>anterior endoderm</rdfs:label>
    </owl:Class>
    <owl:Axiom>
