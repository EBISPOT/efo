        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
        <owl:annotatedTarget>longitudinal tract of ventral nerve cord</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0237252</oboInOwl:hasDbXref>
    </owl:Axiom>
