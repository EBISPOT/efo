        <oboInOwl:hasNarrowSynonym>SEG</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>SOG</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>adult subesophageal ganglion</oboInOwl:hasNarrowSynonym>
