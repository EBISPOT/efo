        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>neurogenic region</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001057"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Region that gives rise to the neuroblasts of the central nervous system (Bossing et al., 1996). An anterior region (procephalic neurogenic region) gives rise to the brain and a posterior, ventral region (ventral neuroectoderm) gives rise to the ventral nerve cord and gnathal ganglia (Bossing et al., 1996).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
