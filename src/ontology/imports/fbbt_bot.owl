    <!-- http://purl.obolibrary.org/obo/FBbt_00052061 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00052061">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048491"/>
