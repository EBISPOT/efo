                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001787"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An elongate muscular pouch, the anterior part of which is the uterus, where eggs are fertilized, and the posterior part of which is the vagina, where insemination takes place during copulation (McQueen et al., 2022). It opens posteriorly through the vulva (McQueen et al., 2022).</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>FBbt:00004919</oboInOwl:hasAlternativeId>
        <oboInOwl:hasNarrowSynonym>uterus</oboInOwl:hasNarrowSynonym>
