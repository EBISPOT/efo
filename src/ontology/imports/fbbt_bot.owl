    <!-- http://purl.obolibrary.org/obo/FBbt_00007321 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00007321">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001666"/>
        <obo:IAO_0000115>Embryonic precursor of a cardial cell, which forms part of the inner, contractile layer of the dorsal vessel. These cells become morphologically distinct during stage 14, when they stretch, flatten and develop dorsally directed processes (Campos-Ortega and Hartenstein, 1997). During dorsal closure, they are squeezed between the amnioserosa and epidermis, and the cardioblasts of either side meet at the dorsal midline once the amnioserosa separates from the epidermis (Campos-Ortega and Hartenstein, 1997). The dorsal vessel is formed when the lateral edges of the cardioblasts curve around ventrally to meet and interdigitate leaving a medial lumen (Campos-Ortega and Hartenstein, 1997). These cells do not finish differentiating into specialized subtypes until after larval hatching (Lehmacher et al., 2012).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-7073-9172"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2008-12-03T02:19:59Z</terms:date>
        <oboInOwl:hasExactSynonym>embryonic cardiomyoblast</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00007321</oboInOwl:id>
        <rdfs:label>embryonic cardioblast</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007321"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Embryonic precursor of a cardial cell, which forms part of the inner, contractile layer of the dorsal vessel. These cells become morphologically distinct during stage 14, when they stretch, flatten and develop dorsally directed processes (Campos-Ortega and Hartenstein, 1997). During dorsal closure, they are squeezed between the amnioserosa and epidermis, and the cardioblasts of either side meet at the dorsal midline once the amnioserosa separates from the epidermis (Campos-Ortega and Hartenstein, 1997). The dorsal vessel is formed when the lateral edges of the cardioblasts curve around ventrally to meet and interdigitate leaving a medial lumen (Campos-Ortega and Hartenstein, 1997). These cells do not finish differentiating into specialized subtypes until after larval hatching (Lehmacher et al., 2012).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0151925</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0219200</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007321"/>
        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasExactSynonym"/>
        <owl:annotatedTarget>embryonic cardiomyoblast</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0219200</oboInOwl:hasDbXref>
    </owl:Axiom>
    


