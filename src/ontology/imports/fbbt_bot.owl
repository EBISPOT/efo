                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Digestive system of the adult, comprising the alimentary canal, mouthparts, labellar glands, salivary glands and Malpighian tubules (Miller, 1950). The adult alimentary canal and salivary glands arise anew from precursors during metamorphosis (Bodenstein, 1950). The adult Malpighian tubules are remodelled from those of the larva (Bodenstein, 1950).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>pupal/adult digestive system</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00003123</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>adult digestive system</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003123"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Digestive system of the adult, comprising the alimentary canal, mouthparts, labellar glands, salivary glands and Malpighian tubules (Miller, 1950). The adult alimentary canal and salivary glands arise anew from precursors during metamorphosis (Bodenstein, 1950). The adult Malpighian tubules are remodelled from those of the larva (Bodenstein, 1950).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007733</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007735</oboInOwl:hasDbXref>
    </owl:Axiom>
    


