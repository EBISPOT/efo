        <oboInOwl:id>FBbt:00004925</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>genital chamber</rdfs:label>
    </owl:Class>
    <owl:Axiom>
