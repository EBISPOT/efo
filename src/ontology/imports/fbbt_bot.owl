    <!-- http://purl.obolibrary.org/obo/FBbt_00005800 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005800">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005757"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001718"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Neuroendocrine structure that forms part of the ring gland. In the embryo and larva it is found dorsal the aorta, anterior to the brain (Dai and Gilbert, 1991; de Velasco et al., 2004, Nassel and Zandawala, 2020). It migrates posteriorly during metamorphosis (Dai and Gilbert, 1991) and in the adult it is found posterior to the brain, dorsal to the corpus cardiacum (Nassel and Zandawala, 2020). It produces juvenile hormone (Dai and Gilbert, 1991; Hartenstein, 1993; Nassel and Zandawala, 2020).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:0001057</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>CA</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005800</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>corpus allatum</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005800"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Neuroendocrine structure that forms part of the ring gland. In the embryo and larva it is found dorsal the aorta, anterior to the brain (Dai and Gilbert, 1991; de Velasco et al., 2004, Nassel and Zandawala, 2020). It migrates posteriorly during metamorphosis (Dai and Gilbert, 1991) and in the adult it is found posterior to the brain, dorsal to the corpus cardiacum (Nassel and Zandawala, 2020). It produces juvenile hormone (Dai and Gilbert, 1991; Hartenstein, 1993; Nassel and Zandawala, 2020).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0053727</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064803</oboInOwl:hasDbXref>
