    <!-- http://purl.obolibrary.org/obo/FBbt_00001837 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001837">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001760"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001882"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000449"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00110875"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A cluster consisting of adult midgut precursor cells and peripheral cells found adjacent to the basement membrane of the larval midgut. These clusters are scattered throughout the larval midgut. They form by division of adult midgut precursor cells during larval stages. The first division is asymmetrical, producing a peripheral cell, which extends its processes around the adult midgut precursor cells (Mathur et al., 2010).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>midgut imaginal histoblasts</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00001837</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>midgut imaginal island</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001837"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A cluster consisting of adult midgut precursor cells and peripheral cells found adjacent to the basement membrane of the larval midgut. These clusters are scattered throughout the larval midgut. They form by division of adult midgut precursor cells during larval stages. The first division is asymmetrical, producing a peripheral cell, which extends its processes around the adult midgut precursor cells (Mathur et al., 2010).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064792</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0209706</oboInOwl:hasDbXref>
    </owl:Axiom>
    


