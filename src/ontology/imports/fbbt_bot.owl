    <!-- http://purl.obolibrary.org/obo/FBbt_00047117 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00047117">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001104"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001105"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Ventral subdivision of the larval anterior commissure (Truman et al., 2004; Birkholz et al., 2015). It is prominent in the thoracic neuromeres, reduced in A1, rudimentary in all other abdominal neuromeres and absent from the gnathal segments (Birkholz et al., 2015). In abdominal segments, it is formed predominantly from lineage 9 neurons (Truman et al., 2004).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-01-07T13:01:41Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00047117</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>aV</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>larval antero-ventral commissure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047117</oboInOwl:id>
        <rdfs:label>larval anterior ventral commissure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047117"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Ventral subdivision of the larval anterior commissure (Truman et al., 2004; Birkholz et al., 2015). It is prominent in the thoracic neuromeres, reduced in A1, rudimentary in all other abdominal neuromeres and absent from the gnathal segments (Birkholz et al., 2015). In abdominal segments, it is formed predominantly from lineage 9 neurons (Truman et al., 2004).</owl:annotatedTarget>
