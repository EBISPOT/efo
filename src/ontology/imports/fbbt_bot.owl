    <!-- http://purl.obolibrary.org/obo/FBbt_00001766 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001766">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001761"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001652"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Imaginal disc that, in the adults, gives rise to the eye, antenna, head capsule (including all bristles and external membranes) and the maxillary palps (Cohen, 1993).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:6001766</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
