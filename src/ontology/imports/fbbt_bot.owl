        <obo:IAO_0000115>Glial cell of the adult that is associated with the cell body rind of the brain. They have multiple lamelliform processes that intercalate in between neurons and wrap neuronal cell bodies (Hartenstein, 2011). They also wrap neuronal processes as they travel across the cell body rind (Kremer et al., 2017).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://www.researchgate.net/scientific-contributions/Simon-Reeve-2162827703"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2011-04-26T02:25:30Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00100501</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>adult brain CG</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>adult brain cortex associated glial cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>adult brain cortex glial cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00100501</oboInOwl:id>
        <rdfs:label>adult brain cell body glial cell</rdfs:label>
    </owl:Class>
