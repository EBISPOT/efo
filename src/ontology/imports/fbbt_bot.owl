                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003019"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A spiracle of the adult thorax. There are 2 pairs of these, in segments T2 and T3. Each has a two lipped external rim that can be closed by the action of an associated spiracular occlusor muscle (FBbt:00013335).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00014814</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Manning and Krasnow (1993) assign the anterior spiracle to the mesothoracic segment, as we have done here, despite recording its origin as being from tracheoblasts associated with the humeral (dorsal prothoracic) disc.</rdfs:comment>
        <rdfs:label>adult thoracic spiracle</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00014814"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A spiracle of the adult thorax. There are 2 pairs of these, in segments T2 and T3. Each has a two lipped external rim that can be closed by the action of an associated spiracular occlusor muscle (FBbt:00013335).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007734</oboInOwl:hasDbXref>
    </owl:Axiom>
    


