                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00018004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Small ganglion of the embryonic/larval stomatogastric nervous system located on the right hand side of the larva, between the two brain hemispheres, behind the supraesophageal commissure. It is elongated, less compact than the hypoesophageal ganglion and occupies a more ventral position, closely attached to the esophageal wall. It contains 10-12 neurons.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00002635</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>EG</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>esophageal ganglion</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>esophageal ganglion 1</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>paraoesophageal ganglion</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00002635</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>paraesophageal ganglion</rdfs:label>
    </owl:Class>
    <owl:Axiom>
