        <obo:IAO_0000115>A subdivision of the cell body rind of the central nervous system. It includes the neuronal cell bodies.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://www.researchgate.net/scientific-contributions/Simon-Reeve-2162827703"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2010-09-08T02:26:08Z</terms:date>
