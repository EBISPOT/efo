                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A ventrally located air sac of the metathorax. It arises from the lateral trunk and extends ventrally into the base of the metathoracic leg. The metathoracic (posterior thoracic) spiracle opens into this air sac.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00003109</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>hypopleural air sac</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003109"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A ventrally located air sac of the metathorax. It arises from the lateral trunk and extends ventrally into the base of the metathoracic leg. The metathoracic (posterior thoracic) spiracle opens into this air sac.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBim0000051</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBim0000052</oboInOwl:hasDbXref>
