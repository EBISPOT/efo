            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Superficial layer of the brain, composed of glia and the cell bodies of neurons (soma).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00003625</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>adult brain cortex</oboInOwl:hasExactSynonym>
