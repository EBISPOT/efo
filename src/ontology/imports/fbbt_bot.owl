    <!-- http://purl.obolibrary.org/obo/FBbt_00047118 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00047118">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005103"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001105"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Intermediate subdivision of the larval anterior commissure (Truman et al., 2004; Birkholz et al., 2015). It is found in all thoracic neuromeres and, at a significantly reduced size, in the labial (S3) and A1 neuromeres (Birkholz et al., 2015). There is one anterior intermediate commissure in the anterior gnathal ganglion (S1/S2) (Kuert et al., 2014).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-01-07T13:10:45Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00047118</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>aI</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>larval antero-intermediate commissure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047118</oboInOwl:id>
        <rdfs:label>larval anterior intermediate commissure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
