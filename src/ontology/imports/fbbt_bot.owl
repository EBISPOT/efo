            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Region of the developing embryonic central nervous system that is derived from the mesectoderm and found at the midline (Kearney et al., 2004). The mesectodermal cells have undergone further cell division and differentiation and a metameric organization is now more apparent (Kearney et al., 2004).</obo:IAO_0000115>
        <oboInOwl:hasNarrowSynonym>embryonic mature midline</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005528</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Kearney et al. (2004) refer to this as &apos;mature midline&apos; from stage 13, despite the presence of immature cells.</rdfs:comment>
        <rdfs:label>midline primordium</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005528"/>
