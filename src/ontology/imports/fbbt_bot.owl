        <oboInOwl:hasExactSynonym>lateral proliferation zone</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>lpo</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001939</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>lamina anlage</rdfs:label>
