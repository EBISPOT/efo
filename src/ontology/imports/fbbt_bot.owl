    <!-- http://purl.obolibrary.org/obo/FBbt_00003688 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00003688">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040007"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00049824"/>
        <obo:IAO_0000115>The mushroom body lobe system consists of a vertical (dorsal) branch and a medial branch. In the larva, there are only two lobes (one dorsal, one medial), but remodeling during the pupal stage results in five lobes (two dorsal, three medial) in the adult (Lee et al., 1999).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00003688</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>lobe of corpora pedunculata</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>lobe of mushroom body</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00003688</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>lobe system of mushroom body</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003688"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>The mushroom body lobe system consists of a vertical (dorsal) branch and a medial branch. In the larva, there are only two lobes (one dorsal, one medial), but remodeling during the pupal stage results in five lobes (two dorsal, three medial) in the adult (Lee et al., 1999).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0105215</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0111409</oboInOwl:hasDbXref>
