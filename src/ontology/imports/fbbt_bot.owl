    <!-- http://purl.obolibrary.org/obo/FBbt_00001761 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001761">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001760"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007010"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025993"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001649"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A sac shaped epithelial structure in the larva that gives rise to part of the adult integumentary system. One side of the sac consists of peripodial epithelium, the other of columnar epithelium. A single anterior-posterior compartment boundary bisects both peripodial membrane and columnar epithelium. Cells do not cross this boundary during growth and development of the disc.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:0000939</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>imaginal disk</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00001761</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#FB_gloss"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>imaginal disc</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001761"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A sac shaped epithelial structure in the larva that gives rise to part of the adult integumentary system. One side of the sac consists of peripodial epithelium, the other of columnar epithelium. A single anterior-posterior compartment boundary bisects both peripodial membrane and columnar epithelium. Cells do not cross this boundary during growth and development of the disc.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FBC:GG</oboInOwl:hasDbXref>
    </owl:Axiom>
    


