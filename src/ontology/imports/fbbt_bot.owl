    <!-- http://purl.obolibrary.org/obo/FBbt_00001075 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001075">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001070"/>
        <obo:IAO_0000115>Precursor cell of the embryonic stomatogastric nervous system that delaminates from the tip of each of the three iSNSPs pouches at mid-embryonic stage 12. After delamination, they move anteriorly and become part of the frontal ganglion.</obo:IAO_0000115>
