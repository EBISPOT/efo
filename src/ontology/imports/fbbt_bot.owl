                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001102"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The region of the adult central nervous system posterior to the brain, containing all of the thoracic and abdominal neuromeres (Court et al., 2020). It exists as a single consolidated ganglion located in the ventral part of the thorax (Court et al., 2020). It is connected to the brain by descending and ascending neurons that pass through the neck connective (Court et al., 2020).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00004052</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>TAC</oboInOwl:hasExactSynonym>
