            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00052193"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Thin layer of larval synaptic neuropil found lateral to the superior medial protocerebrum, separated from it by axon bundles of the DPlc lineages (Hartenstein et al., 2015). It is the precursor to the adult superior lateral protocerebrum and lateral horn domains (Pereanu et al., 2010; Hartenstein et al., 2015).</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>CPLd</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>dorsal centro-posterior lateral synaptic neuropil domain</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>VFB:FBbt_00007064</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>larvalbrain_neuropil:408</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>larvalbrain_neuropil:586</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>larval SLP</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>larval SLP/LH</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00007064</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#larval_OF"/>
        <rdfs:label>embryonic/larval superior lateral protocerebrum</rdfs:label>
    </owl:Class>
