    <!-- http://purl.obolibrary.org/obo/FBbt_00005565 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00005565">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001332"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00049579"/>
