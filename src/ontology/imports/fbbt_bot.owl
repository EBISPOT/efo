                <owl:someValuesFrom rdf:resource="http://flybase.org/reports/FBgn0001981"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A cell that is a progenitor of the adult midgut and occupies a basal position in the midgut epithelium. It divides during larval stages to form clusters called midgut imaginal islands. Its first division is asymmetric and produces a peripheral cell, subsequent divisions generate more adult midgut progenitor cells (Mathur et al., 2010).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>AMP</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>adult midgut precursor cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>midgut histoblast</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>spindle cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>embryonic precursor cell of adult midgut</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00000449</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>These cells can be identified by their expression of escargot (Jiang and Edgar, 2009).</rdfs:comment>
        <rdfs:label>adult midgut progenitor cell</rdfs:label>
    </owl:Class>
    <owl:Axiom>
