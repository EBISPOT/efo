        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00052057</oboInOwl:id>
        <rdfs:label>epigynial dorsal lobe</rdfs:label>
    </owl:Class>
