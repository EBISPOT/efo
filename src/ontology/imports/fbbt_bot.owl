        <oboInOwl:id>FBbt:00001765</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>clypeo-labral disc</rdfs:label>
    </owl:Class>
    <owl:Axiom>
