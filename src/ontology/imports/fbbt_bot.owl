                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00110694"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Posterior part of the genital chamber (McQueen et al., 2022). It is an ectodermal invagination where insemination takes place (McQueen et al., 2022). It extends from the posterior edge of the uterine specialized intima anteriorly to the vulva posteriorly (McQueen et al., 2022).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-01-18T14:02:31Z</terms:date>
