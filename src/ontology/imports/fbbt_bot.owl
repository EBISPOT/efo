    <!-- http://purl.obolibrary.org/obo/FBbt_00004914 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004914">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048425"/>
