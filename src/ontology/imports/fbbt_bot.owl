        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047554</oboInOwl:id>
        <rdfs:label>adult anterior intermediate commissure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
