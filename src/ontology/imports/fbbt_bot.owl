    <!-- http://purl.obolibrary.org/obo/FBbt_00003626 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00003626">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005137"/>
        <rdfs:subClassOf>
