                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005682"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The embryonic/larval dorsal vessel from its anterior tip to the middle of segment 4, where it broadens to become the heart (Campos-Ortega and Hartenstein, 1997). Its anterior end is a funnel-shaped cardiac outflow tract (Zmojdzian et al., 2008).</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>FBbt:00005683</oboInOwl:hasAlternativeId>
        <oboInOwl:hasExactSynonym>larval aorta</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001674</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>embryonic/larval aorta</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001674"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>The embryonic/larval dorsal vessel from its anterior tip to the middle of segment 4, where it broadens to become the heart (Campos-Ortega and Hartenstein, 1997). Its anterior end is a funnel-shaped cardiac outflow tract (Zmojdzian et al., 2008).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0204371</oboInOwl:hasDbXref>
    </owl:Axiom>
    


