    <!-- http://purl.obolibrary.org/obo/FBbt_00001862 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001862">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005379"/>
