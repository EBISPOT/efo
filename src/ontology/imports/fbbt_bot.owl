                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003708"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A zone of proliferating neuroblasts that forms at mid third instar, at the lateral rim of the outer optic anlage. Descendants of these neuroblasts form the adult lamina.</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>FBbt:00001950</oboInOwl:hasAlternativeId>
