        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00111688"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Dorsolateral horn-shaped synaptic neuropil domain of the adult protocerebrum that houses the terminals of various antennal lobe projection neurons (Ito et al., 2014). It is not separated from other neuropils by a glial sheath, but by the extent of arborization and synapsing of these antennal lobe projection neurons (Ito et al., 2014).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00007053</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>LH</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>lateral protocerebrum</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00007053</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <rdfs:label>adult lateral horn</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007053"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Dorsolateral horn-shaped synaptic neuropil domain of the adult protocerebrum that houses the terminals of various antennal lobe projection neurons (Ito et al., 2014). It is not separated from other neuropils by a glial sheath, but by the extent of arborization and synapsing of these antennal lobe projection neurons (Ito et al., 2014).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0211016</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0224194</oboInOwl:hasDbXref>
