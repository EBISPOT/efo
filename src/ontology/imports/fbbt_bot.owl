        <owl:annotatedTarget>SLP</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0224194</oboInOwl:hasDbXref>
        <oboInOwl:hasSynonymType rdf:resource="http://purl.obolibrary.org/obo/fbbt#BRAIN_NAME_ABV"/>
    </owl:Axiom>
