        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00100741</oboInOwl:id>
        <rdfs:label>neuroblast BA</rdfs:label>
    </owl:Class>
