    <!-- http://purl.obolibrary.org/obo/FBbt_00052067 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00052067">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048491"/>
