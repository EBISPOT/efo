        <rdfs:label>uterus</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004924"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Anterior part of the genital chamber (McQueen et al., 2022). It is an ectodermal invagination that is the site of egg fertilization (McQueen et al., 2022). It is connected to the common oviduct anterodorsally and the vagina posteriorly (McQueen et al., 2022). It is surrounded by muscles (McQueen et al., 2022).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007735</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0253444</oboInOwl:hasDbXref>
    </owl:Axiom>
    


