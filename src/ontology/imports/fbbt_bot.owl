    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000125"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Innermost germ layer of the embryo (Campos-Ortega and Hartenstein, 1997). It is formed by the invagination of two anlagen, those of the anterior and posterior midgut (Campos-Ortega and Hartenstein, 1997).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0089570</oboInOwl:hasDbXref>
