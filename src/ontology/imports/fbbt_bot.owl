        <oboInOwl:id>FBbt:00110924</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Some cells receive input from Dh44 neurons and some are premotor neurons (King et al., 2017).</rdfs:comment>
        <rdfs:label>adult Hugin neuron</rdfs:label>
    </owl:Class>
