    <!-- http://purl.obolibrary.org/obo/FBbt_00059338 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00059338">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004208"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005495"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00000126"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Posterior-most region of the mesoderm. At the blastoderm stage, it comprises about 40 cells (Sun et al., 2023). It gives rise to the founder cells of the longitudinal midgut muscles (Ismat et al., 2010) and the stellate cells of the Malpighian tubules (Denholm et al., 2003).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-6095-8718"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-01-16T14:23:32Z</terms:date>
        <oboInOwl:hasExactSynonym>posterior mesoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00059338</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>caudal mesoderm</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00059338"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Posterior-most region of the mesoderm. At the blastoderm stage, it comprises about 40 cells (Sun et al., 2023). It gives rise to the founder cells of the longitudinal midgut muscles (Ismat et al., 2010) and the stellate cells of the Malpighian tubules (Denholm et al., 2003).</owl:annotatedTarget>
