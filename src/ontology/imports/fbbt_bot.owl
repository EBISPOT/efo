        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Air-filled network of tracheae, opening to the exterior via spiracles and containing minute tracheoles where gaseous exchange between air and tissues occurs (Miller, 1950).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0007735</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0064787</oboInOwl:hasDbXref>
