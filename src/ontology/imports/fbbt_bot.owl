    <!-- http://purl.obolibrary.org/obo/FBbt_00003143 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00003143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005384"/>
