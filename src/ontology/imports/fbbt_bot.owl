        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasDbXref"/>
        <owl:annotatedTarget>Reactome:R-HSA-112310</owl:annotatedTarget>
        <rdfs:label>Neurotransmitter release cycle</rdfs:label>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/GO_0007271 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0007271">
