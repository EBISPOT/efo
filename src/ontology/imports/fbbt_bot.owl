        <obo:IAO_0000028>LHN</obo:IAO_0000028>
        <obo:IAO_0000115>Adult neuron that has dendritic arbors in the lateral horn (including local neurons). Many of these receive olfactory input from antennal lobe projection neurons.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
