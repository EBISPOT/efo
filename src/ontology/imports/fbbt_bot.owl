        <oboInOwl:hasRelatedSynonym>myofibril</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00005074</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#scrnaseq_slim"/>
        <rdfs:comment>In contrast to vertebrates, in Drosophila embryos and larva, each muscle is a single myotube (Maqbool and Jagla, 2007).</rdfs:comment>
        <rdfs:label>muscle cell</rdfs:label>
    </owl:Class>
