    <!-- http://purl.obolibrary.org/obo/FBbt_00001369 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001369">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025993"/>
