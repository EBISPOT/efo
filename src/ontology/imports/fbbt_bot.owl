                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001120"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Intermediate subdivision of the larval posterior commissure (Truman et al., 2004; Birkholz et al., 2015). It is found in all thoracic neuromeres and, at a significantly reduced size, in the labial (S3) and A1 neuromeres (Birkholz et al., 2015). It is absent from the anterior gnathal ganglion (S1/S2) (Kuert et al., 2014).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-01-07T13:22:49Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00047120</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>larval postero-intermediate commissure</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>pI</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00047120</oboInOwl:id>
        <rdfs:label>larval posterior intermediate commissure</rdfs:label>
    </owl:Class>
