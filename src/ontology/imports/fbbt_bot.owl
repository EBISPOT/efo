        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00058145"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001685"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Plasmatocyte of the adult. These cells all originate during embryonic and larval development. They do not divide in the adult and their numbers decrease slowly throughout adult life (Honti et al., 2014).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-6095-8718"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-05-26T15:17:34Z</terms:date>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00058144</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>adult plasmatocyte</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00058144"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Plasmatocyte of the adult. These cells all originate during embryonic and larval development. They do not divide in the adult and their numbers decrease slowly throughout adult life (Honti et al., 2014).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0223115</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00058145 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00058145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005063"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002292"/>
                <owl:someValuesFrom rdf:resource="http://flybase.org/reports/FBgn0259896"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Phagocytic hemocyte. These cells represent about 90% of all hemocytes (Lanot et al., 2001). They are responsible for the engulfment of small particles, microbes and apoptotic tissues debris (Honti et al., 2014) and for the secretion of antimicrobial peptides and opsonins (Cattenoz et al., 2021). They also contribute to the production and secretion of proteins of the hemolymph, along with fat body cells (Cattenoz et al., 2021). They express Nimrod C1 (Kurucz et al., 2007).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-6095-8718"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-05-26T15:18:53Z</terms:date>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00058145</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>plasmatocyte</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00058145"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Phagocytic hemocyte. These cells represent about 90% of all hemocytes (Lanot et al., 2001). They are responsible for the engulfment of small particles, microbes and apoptotic tissues debris (Honti et al., 2014) and for the secretion of antimicrobial peptides and opsonins (Cattenoz et al., 2021). They also contribute to the production and secretion of proteins of the hemolymph, along with fat body cells (Cattenoz et al., 2021). They express Nimrod C1 (Kurucz et al., 2007).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0134542</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0195027</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0223115</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0248467</oboInOwl:hasDbXref>
    </owl:Axiom>
    


