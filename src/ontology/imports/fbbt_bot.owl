    <!-- http://purl.obolibrary.org/obo/FBbt_00004021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001976"/>
