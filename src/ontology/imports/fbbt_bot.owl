        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A cell that is the principal cell type of the fat body and is filled with lipid droplets.</owl:annotatedTarget>
