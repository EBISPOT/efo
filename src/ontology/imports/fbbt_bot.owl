    <!-- http://purl.obolibrary.org/obo/FBbt_00001845 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001845">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007245"/>
        <rdfs:subClassOf>
