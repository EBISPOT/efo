                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025990"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Outermost germ layer of the embryo (Campos-Ortega and Hartenstein, 1997). It is formed from the ectoderm anlage, which includes the cells of the cellular blastoderm monolayer that do not invaginate during gastrulation (Campos-Ortega and Hartenstein, 1997).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>UBERON:0000924</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
