            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Neuroblast that divides asymmetrically to regenerate itself and produce a smaller ganglion mother cell that generates two daughter neurons. Many of these neuroblasts switch to type 0 division at some point during their development, to produce daughters that develop into neurons with no further division (Baumgardt et al., 2014).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://www.researchgate.net/scientific-contributions/Simon-Reeve-2162827703"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2011-06-06T02:39:05Z</terms:date>
        <oboInOwl:hasDbXref>VFB:FBbt_00100532</oboInOwl:hasDbXref>
        <oboInOwl:hasNarrowSynonym>type 0 neuroblast</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00100532</oboInOwl:id>
        <rdfs:comment>Bayraktar et al. (2010) show that type I neuroblasts can be distinguished from type II neuroblasts as being Deadpan-, Prospero- and Asense-positive.</rdfs:comment>
        <rdfs:label>type I neuroblast</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00100532"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Neuroblast that divides asymmetrically to regenerate itself and produce a smaller ganglion mother cell that generates two daughter neurons. Many of these neuroblasts switch to type 0 division at some point during their development, to produce daughters that develop into neurons with no further division (Baumgardt et al., 2014).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0207387</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0225698</oboInOwl:hasDbXref>
