    <!-- http://purl.obolibrary.org/obo/FBbt_00040007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00040007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007060"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040005"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040005"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/FBbt_00100200"/>
        <obo:IAO_0000115>Region of synaptic neuropil whose boundaries are largely discontinuities in the density of presynaptic terminals: high density in the synaptic neuropil domain, lower or zero density outside this region. These boundaries often correspond to a boundary with glial sheath, tract neuropil or cortex.</obo:IAO_0000115>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2009-12-09T05:03:55Z</terms:date>
        <oboInOwl:hasDbXref>UBERON:6040007</oboInOwl:hasDbXref>
