        <oboInOwl:hasRelatedSynonym>SPG</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00003626</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#BrainName"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>In the adult, this region is referred to as cerebral ganglia (Ito et al., 2014).</rdfs:comment>
        <rdfs:label>supraesophageal ganglion</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00003626"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
