        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00052061</oboInOwl:id>
        <rdfs:label>vagina</rdfs:label>
    </owl:Class>
    <owl:Axiom>
