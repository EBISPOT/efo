                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00110687"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Small, bilaterally paired gland that lies caudal to the spermathecae and is connected to the uterus by a duct (McQueen et al., 2022). The gland wall consists of a single layer of secretory cells, each with a large vacuole and a minute acidophilic granule towards the gland lumen (McQueen et al., 2022). It arises from the segment 9 (male genital) primordium in the female genital disc (McQueen et al., 2022).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>appendicular gland</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>colleterial gland</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>female AcGl</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>parovarium</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00004914</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>female accessory gland</rdfs:label>
    </owl:Class>
    <owl:Axiom>
