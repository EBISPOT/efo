        <oboInOwl:id>GO:0071478</oboInOwl:id>
        <rdfs:comment>Note that &apos;radiation&apos; refers to electromagnetic radiation of any wavelength.</rdfs:comment>
        <rdfs:label>cellular response to radiation</rdfs:label>
    </owl:Class>
