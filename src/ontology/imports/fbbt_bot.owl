            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Posterior portion of the embryonic/larval pharynx, posterior to the atrium.</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>FBbt:00005766</oboInOwl:hasAlternativeId>
        <oboInOwl:hasExactSynonym>embryonic/larval atrium</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>larval cibarium</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001844</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:comment>Jurgens et al. (1986) define the larval cibarium as being the same as the pharynx, and posterior to the atrium. However, Campos-Ortega and Hartenstein (1985) define it as being the same as the atrium, and anterior to the pharynx. We follow the latter. mc140708.</rdfs:comment>
