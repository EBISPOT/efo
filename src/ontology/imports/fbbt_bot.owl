                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0038023"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Any process that modulates the frequency, rate or extent of a signaling receptor activity. Receptor activity is when a molecule combines with an extracellular or intracellular messenger to initiate a change in cell activity.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>regulation of receptor activity</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym>regulation of signalling receptor activity</oboInOwl:hasExactSynonym>
