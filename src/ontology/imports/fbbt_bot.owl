        <oboInOwl:hasExactSynonym>polygonal cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>prohaemocyte</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
