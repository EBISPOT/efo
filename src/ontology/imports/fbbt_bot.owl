                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001786"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A duct connecting the female accessory gland to the uterus, opening just caudal to the spermathecal ducts (McQueen et al., 2022). It consists of a tube of thin epithelium lined with a thin chitinous intima, irregularly ringed with sharp ridges that project into the lumen (McQueen et al., 2022). It develops from the male genital primordium of the female genital disc (Keisman et al., 2001).</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00004915</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>female accessory gland duct</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004915"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A duct connecting the female accessory gland to the uterus, opening just caudal to the spermathecal ducts (McQueen et al., 2022). It consists of a tube of thin epithelium lined with a thin chitinous intima, irregularly ringed with sharp ridges that project into the lumen (McQueen et al., 2022). It develops from the male genital primordium of the female genital disc (Keisman et al., 2001).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0141451</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0186027</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0253444</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/FBbt_00004918 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00004918">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007474"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00048491"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004912"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004865"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
