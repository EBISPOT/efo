        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <rdfs:label>sensory neuron</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CL_0000101"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Any neuron having a sensory function; an afferent neuron conveying sensory impulses.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>ISBN:0721662544</oboInOwl:hasDbXref>
