        <oboInOwl:hasRelatedSynonym>venNeurP3</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ventral neurectoderm</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ventral neuroderm primordium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ventral neuroectoderm</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00005554</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
