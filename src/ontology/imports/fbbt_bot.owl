        <obo:IAO_0000115>Adult neuron that expresses Hugin. These neurons have their cell bodies in the subesophageal zone and collectively project to the ring gland, protocerebrum and ventral nerve cord (Melcher and Pankratz, 2005).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-5948-3092"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2014-08-14T17:55:17Z</terms:date>
