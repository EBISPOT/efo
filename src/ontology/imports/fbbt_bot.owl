    <!-- http://purl.obolibrary.org/obo/GO_0007154 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0007154">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0009987"/>
        <obo:IAO_0000115>Any process that mediates interactions between a cell and its surroundings. Encompasses interactions such as signaling or attachment between one cell and another cell, between a cell and an extracellular matrix, or between a cell and any other aspect of its environment.</obo:IAO_0000115>
