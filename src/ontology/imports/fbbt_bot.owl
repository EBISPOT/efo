    <!-- http://purl.obolibrary.org/obo/FBbt_00001104 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00001104">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/FBbt_00049998"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001727"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00047551"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00049998"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001102"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Commissure of the ventral nerve cord at late embryonic or larval stages. There are two main commissures per segment, anterior and posterior, but the posterior commissure is not present in A9 (Landgraf et al., 2003; Birkholz et al., 2015). In some segments, at some stages these can be further divided into multiple components along the dorsal-ventral axis (Truman et al., 2004; Birkholz et al., 2015; Hartenstein et al., 2018).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>VFB:FBbt_00001104</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00001104</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>larval ventral nerve cord commissure</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001104"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Commissure of the ventral nerve cord at late embryonic or larval stages. There are two main commissures per segment, anterior and posterior, but the posterior commissure is not present in A9 (Landgraf et al., 2003; Birkholz et al., 2015). In some segments, at some stages these can be further divided into multiple components along the dorsal-ventral axis (Truman et al., 2004; Birkholz et al., 2015; Hartenstein et al., 2018).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FlyBase:FBrf0160715</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FlyBase:FBrf0180161</oboInOwl:hasDbXref>
