        <oboInOwl:hasRelatedSynonym>taste-sensory region glomerulus</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>FBbt:00051393</oboInOwl:id>
        <rdfs:label>adult sensory region of subesophageal zone</rdfs:label>
    </owl:Class>
