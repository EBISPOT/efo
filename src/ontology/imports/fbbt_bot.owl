        <obo:IAO_0000115>Any larval anterior commissure (FBbt:00001105) that is part of some larval maxillary neuromere (FBbt:00001975).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-1373-1705"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2018-10-26T14:40:41Z</terms:date>
