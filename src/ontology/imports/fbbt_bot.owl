    <!-- http://purl.obolibrary.org/obo/FBbt_00007053 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00007053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00040007"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007145"/>
