    <!-- http://purl.obolibrary.org/obo/PATO_0002309 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0002309">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0002226"/>
        <obo:IAO_0000115>A convex 3-D shape quality inhering in a bearer by virtue of the bearer&apos;s exhibiting a by virtue of the bearer&apos;s exhibiting a consistently sized and approximately round cross-section along its length, which is many times larger than its diameter.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-2061-091X"/>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:id>PATO:0002309</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/pato#value_slim"/>
        <rdfs:comment>Note that a fiber shaped object may take any circuitous or straight path through space (think of a length of string or rope).</rdfs:comment>
        <rdfs:label>fiber shaped</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0002309"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A convex 3-D shape quality inhering in a bearer by virtue of the bearer&apos;s exhibiting a by virtue of the bearer&apos;s exhibiting a consistently sized and approximately round cross-section along its length, which is many times larger than its diameter.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PATOC:DC</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/PATO_0002318 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/PATO_0002318">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/PATO_0002006"/>
        <obo:IAO_0000115>A shape constituting a transition between a rectangle and a circle; a closed curve, of which the circle and ellipse are special cases, whose parametric equation is x = a.cos2/rt, y = b.cos2/rt</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-2061-091X"/>
        <oboInOwl:hasExactSynonym>Lamé curve</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>quality</oboInOwl:hasOBONamespace>
        <oboInOwl:id>PATO:0002318</oboInOwl:id>
        <rdfs:label>superelliptic</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/PATO_0002318"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A shape constituting a transition between a rectangle and a circle; a closed curve, of which the circle and ellipse are special cases, whose parametric equation is x = a.cos2/rt, y = b.cos2/rt</owl:annotatedTarget>
        <oboInOwl:hasDbXref>wiktionary:superellipse</oboInOwl:hasDbXref>
    </owl:Axiom>
    


