                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002131"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001882"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
