    <!-- http://purl.obolibrary.org/obo/FBbt_00002665 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/FBbt_00002665">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00004135"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007236"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00007335"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/FBbt_00025991"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00001866"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00016001"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Larval sense organ of the intercalary segment that is found on the floor of the larval pharynx (Campos-Ortega and Hartenstein, 1997). Its cuticular elements appear as two small bulges on each side, with minute rods facing the cytoplasm (Jurgens et al., 1986). Each of these two sensilla houses three neurons (Gendre et al., 2004), which follow the hypopharyngeal nerve (Campos-Ortega and Hartenstein, 1997).</obo:IAO_0000115>
        <oboInOwl:hasExactSynonym>Organ X</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>PPS</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>hpo</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>hypopharyngeal organ</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>posterior pharyngeal sensilla</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>pps</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00002665</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#EmbDevSlim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>posterior pharyngeal sense organ</rdfs:label>
    </owl:Class>
    <owl:Axiom>
