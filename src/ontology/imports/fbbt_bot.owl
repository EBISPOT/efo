        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>anal pad</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/FBbt_00005785"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Plate or plates that surrounds the anus.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0001-5948-3092</oboInOwl:hasDbXref>
