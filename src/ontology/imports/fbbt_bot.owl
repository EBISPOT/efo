                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/FBbt_00058111"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Muscle cell that serves to change the position of some part of the body. These cells are usually attached to the body wall. Fibers of somatic muscles are multinucleate, with the contractile material grouped into fibrils.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>CL:0008004</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>Somatic and visceral muscles appear striated (Miller, 1950).</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>skeletal muscle cell</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>fly_anatomy.ontology</oboInOwl:hasOBONamespace>
        <oboInOwl:id>FBbt:00005073</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>somatic muscle cell</rdfs:label>
    </owl:Class>
