        <oboInOwl:id>FBbt:00001105</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/fbbt#cur"/>
        <rdfs:label>larval anterior commissure</rdfs:label>
    </owl:Class>
