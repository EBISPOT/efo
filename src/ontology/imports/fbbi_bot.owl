                                        <swrl:propertyPredicate rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                                        <swrl:argument1 rdf:resource="urn:swrl:var#y"/>
                                        <swrl:argument2 rdf:resource="urn:swrl:var#z"/>
                                    </rdf:Description>
                                </rdf:first>
